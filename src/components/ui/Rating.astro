---
interface Props {
  value: number;
  count?: number;
  showCount?: boolean;
  size?: 'sm' | 'md';
}

const { value, count, showCount = true, size = 'md' } = Astro.props;
const fullStars = Math.floor(value);
const hasHalf = value % 1 >= 0.5;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
---

<div class:list={['rating', `rating--${size}`]} aria-label={`Note : ${value} sur 5`}>
  <div class="rating__stars" aria-hidden="true">
    {Array.from({ length: fullStars }).map(() => (
      <svg viewBox="0 0 20 20" fill="currentColor" class="rating__star rating__star--full">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
    {hasHalf && (
      <svg viewBox="0 0 20 20" class="rating__star rating__star--half">
        <defs>
          <linearGradient id="half-grad">
            <stop offset="50%" stop-color="currentColor" />
            <stop offset="50%" stop-color="#E2E8E5" />
          </linearGradient>
        </defs>
        <path fill="url(#half-grad)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    )}
    {Array.from({ length: emptyStars }).map(() => (
      <svg viewBox="0 0 20 20" fill="#E2E8E5" class="rating__star rating__star--empty">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>
  <span class="rating__value">{value.toFixed(1)}</span>
  {showCount && count !== undefined && (
    <span class="rating__count">({count})</span>
  )}
</div>

<style>
  .rating {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .rating__stars {
    display: flex;
    gap: 1px;
    color: var(--color-accent);
  }

  .rating--sm .rating__star { width: 14px; height: 14px; }
  .rating--md .rating__star { width: 18px; height: 18px; }

  .rating__value {
    font-weight: var(--weight-semibold);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .rating__count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .rating--sm .rating__value,
  .rating--sm .rating__count {
    font-size: var(--text-xs);
  }
</style>
