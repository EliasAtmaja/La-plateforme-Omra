---
interface Props {
  city: 'medina' | 'mecca';
}

const { city } = Astro.props;
---

<div class:list={['city-pattern', `city-pattern--${city}`]} aria-hidden="true">
  {city === 'medina' ? (
    <svg class="city-pattern__svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <defs>
        <pattern id="nabawi-pattern" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
          <!-- Motif inspiré du tapis du Masjid En-Nabawi -->
          <rect width="100" height="100" fill="none" />
          <!-- Cadre géométrique -->
          <rect x="5" y="5" width="90" height="90" fill="none" stroke="#1B6B4A" stroke-width="0.8" rx="2" />
          <rect x="12" y="12" width="76" height="76" fill="none" stroke="#1B6B4A" stroke-width="0.4" rx="1" />
          <!-- Médaillon central -->
          <circle cx="50" cy="50" r="22" fill="none" stroke="#1B6B4A" stroke-width="0.6" />
          <circle cx="50" cy="50" r="16" fill="none" stroke="#8B1A1A" stroke-width="0.4" />
          <circle cx="50" cy="50" r="8" fill="none" stroke="#1B6B4A" stroke-width="0.5" />
          <circle cx="50" cy="50" r="3" fill="#1B6B4A" opacity="0.3" />
          <!-- Motifs floraux aux coins -->
          <circle cx="20" cy="20" r="5" fill="none" stroke="#8B1A1A" stroke-width="0.4" />
          <circle cx="80" cy="20" r="5" fill="none" stroke="#8B1A1A" stroke-width="0.4" />
          <circle cx="20" cy="80" r="5" fill="none" stroke="#8B1A1A" stroke-width="0.4" />
          <circle cx="80" cy="80" r="5" fill="none" stroke="#8B1A1A" stroke-width="0.4" />
          <!-- Lignes décoratives -->
          <line x1="28" y1="50" x2="5" y2="50" stroke="#1B6B4A" stroke-width="0.3" />
          <line x1="72" y1="50" x2="95" y2="50" stroke="#1B6B4A" stroke-width="0.3" />
          <line x1="50" y1="28" x2="50" y2="5" stroke="#1B6B4A" stroke-width="0.3" />
          <line x1="50" y1="72" x2="50" y2="95" stroke="#1B6B4A" stroke-width="0.3" />
          <!-- Pétales -->
          <ellipse cx="50" cy="35" rx="3" ry="6" fill="none" stroke="#1B6B4A" stroke-width="0.3" transform="rotate(0 50 50)" />
          <ellipse cx="65" cy="50" rx="3" ry="6" fill="none" stroke="#1B6B4A" stroke-width="0.3" transform="rotate(90 65 50)" />
          <ellipse cx="50" cy="65" rx="3" ry="6" fill="none" stroke="#1B6B4A" stroke-width="0.3" transform="rotate(0 50 50)" />
          <ellipse cx="35" cy="50" rx="3" ry="6" fill="none" stroke="#1B6B4A" stroke-width="0.3" transform="rotate(90 35 50)" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#nabawi-pattern)" />
    </svg>
  ) : (
    <svg class="city-pattern__svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <defs>
        <pattern id="kiswa-pattern" x="0" y="0" width="120" height="120" patternUnits="userSpaceOnUse">
          <!-- Motif inspiré de la Kiswa de la Kaaba -->
          <rect width="120" height="120" fill="none" />
          <!-- Cadre principal -->
          <rect x="5" y="5" width="110" height="110" fill="none" stroke="#C8A951" stroke-width="0.6" />
          <rect x="10" y="10" width="100" height="100" fill="none" stroke="#C8A951" stroke-width="0.3" />
          <!-- Médaillon octogonal central -->
          <polygon points="60,18 82,28 92,50 82,72 60,82 38,72 28,50 38,28" fill="none" stroke="#C8A951" stroke-width="0.6" />
          <polygon points="60,26 76,34 84,50 76,66 60,74 44,66 36,50 44,34" fill="none" stroke="#C8A951" stroke-width="0.3" />
          <!-- Arabesques centrales -->
          <circle cx="60" cy="50" r="14" fill="none" stroke="#C8A951" stroke-width="0.5" />
          <circle cx="60" cy="50" r="8" fill="none" stroke="#C8A951" stroke-width="0.3" />
          <circle cx="60" cy="50" r="3" fill="#C8A951" opacity="0.2" />
          <!-- Motifs d'angle -->
          <path d="M10,10 Q25,15 20,30" fill="none" stroke="#C8A951" stroke-width="0.3" />
          <path d="M110,10 Q95,15 100,30" fill="none" stroke="#C8A951" stroke-width="0.3" />
          <path d="M10,110 Q25,105 20,90" fill="none" stroke="#C8A951" stroke-width="0.3" />
          <path d="M110,110 Q95,105 100,90" fill="none" stroke="#C8A951" stroke-width="0.3" />
          <!-- Points décoratifs -->
          <circle cx="60" cy="15" r="2" fill="#C8A951" opacity="0.3" />
          <circle cx="60" cy="105" r="2" fill="#C8A951" opacity="0.3" />
          <circle cx="15" cy="50" r="2" fill="#C8A951" opacity="0.3" />
          <circle cx="105" cy="50" r="2" fill="#C8A951" opacity="0.3" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#kiswa-pattern)" />
    </svg>
  )}
</div>

<style>
  .city-pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .city-pattern__svg {
    width: 100%;
    height: 100%;
    opacity: 0.04;
  }

  .city-pattern--mecca {
    background: linear-gradient(180deg, rgba(26, 26, 46, 0.02) 0%, transparent 100%);
  }

  .city-pattern--medina {
    background: linear-gradient(180deg, rgba(27, 107, 74, 0.02) 0%, transparent 100%);
  }
</style>
