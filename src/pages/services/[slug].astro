---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, t, getLocalePath } from '../../i18n/ui';
import { services } from '../../data/services';

export function getStaticPaths() {
  // La planification et le visa ont leur propre page dédiée (planification.astro, visa.astro)
  return services.filter(s => s.slug !== 'planification' && s.slug !== 'visa').map(s => ({ params: { slug: s.slug } }));
}

const lang = getLangFromUrl(Astro.url);
const { slug } = Astro.params;
const service = services.find(s => s.slug === slug)!;

const iconMap: Record<string, string> = {
  calendar: '<svg viewBox="0 0 32 32" fill="none"><rect x="5" y="7" width="22" height="20" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M5 13h22" stroke="currentColor" stroke-width="1.4"/><path d="M11 4v5M21 4v5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><circle cx="11" cy="19" r="1.5" fill="currentColor"/><circle cx="16" cy="19" r="1.5" fill="currentColor"/><circle cx="21" cy="19" r="1.5" fill="currentColor"/></svg>',
  hotel: '<svg viewBox="0 0 32 32" fill="none"><path d="M4 26V10l12-5 12 5v16" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><rect x="12" y="18" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.4"/><path d="M4 26h24" stroke="currentColor" stroke-width="1.4"/></svg>',
  transport: '<svg viewBox="0 0 32 32" fill="none"><rect x="4" y="10" width="24" height="14" rx="3" stroke="currentColor" stroke-width="1.4"/><path d="M8 24v3M24 24v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><circle cx="10" cy="21" r="1.5" fill="currentColor"/><circle cx="22" cy="21" r="1.5" fill="currentColor"/><path d="M4 17h24" stroke="currentColor" stroke-width="1.4"/></svg>',
  support: '<svg viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="11" stroke="currentColor" stroke-width="1.4"/><path d="M12 20a5 5 0 018 0" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="12" cy="14" r="1.2" fill="currentColor"/><circle cx="20" cy="14" r="1.2" fill="currentColor"/></svg>',
  guide: '<svg viewBox="0 0 32 32" fill="none"><circle cx="16" cy="11" r="5" stroke="currentColor" stroke-width="1.4"/><path d="M7 27c0-5 4-9 9-9s9 4 9 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>',
  ritual: '<svg viewBox="0 0 32 32" fill="none"><path d="M16 4l2 6h6l-5 4 2 6-5-4-5 4 2-6-5-4h6l2-6z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M8 24h16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M10 28h12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>',
  shield: '<svg viewBox="0 0 32 32" fill="none"><path d="M16 4l10 4v8c0 6-4 11-10 14-6-3-10-8-10-14V8l10-4z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M12 16l3 3 5-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  history: '<svg viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="11" stroke="currentColor" stroke-width="1.4"/><path d="M16 10v7l4 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  shopping: '<svg viewBox="0 0 32 32" fill="none"><path d="M6 8h3l3 14h12l3-10H10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><circle cx="13" cy="26" r="2" fill="currentColor"/><circle cx="23" cy="26" r="2" fill="currentColor"/></svg>',
  document: '<svg viewBox="0 0 32 32" fill="none"><rect x="7" y="4" width="18" height="24" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M11 10h10M11 15h10M11 20h6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  fast: '<svg viewBox="0 0 32 32" fill="none"><path d="M5 16h6M5 12h4M5 20h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M16 6l-3 10h8l-3 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
};

const typeIconMap: Record<string, string> = {
  private: '<svg viewBox="0 0 20 20" fill="none" width="14" height="14"><circle cx="10" cy="7" r="3" stroke="currentColor" stroke-width="1.3"/><path d="M4 17c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  group: '<svg viewBox="0 0 20 20" fill="none" width="14" height="14"><circle cx="7" cy="7" r="2.5" stroke="currentColor" stroke-width="1.2"/><circle cx="13" cy="7" r="2.5" stroke="currentColor" stroke-width="1.2"/><path d="M2 17c0-2.8 2.2-5 5-5M18 17c0-2.8-2.2-5-5-5M7 12h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>',
  pmr: '<svg viewBox="0 0 20 20" fill="none" width="14" height="14"><circle cx="10" cy="5" r="2" stroke="currentColor" stroke-width="1.2"/><path d="M10 8v4l3 4M10 12H7l-1 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>',
};
---

<BaseLayout title={service.title} description={service.subtitle}>

<!-- Hero -->
<section class="sv-hero">
  <div class="sv-hero__bg">
    <img src={service.heroImage} alt="" loading="eager" />
  </div>
  <div class="sv-hero__overlay"></div>
  <div class="sv-hero__content">
    <a href={getLocalePath(lang, '/')} class="sv-hero__back" aria-label="Retour">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <p class="sv-hero__eyebrow load-rise" style="--load-delay: 100ms">{service.eyebrow}</p>
    <h1 class="sv-hero__title load-rise" style="--load-delay: 250ms">{service.title}</h1>
    <p class="sv-hero__sub load-rise" style="--load-delay: 400ms">{service.subtitle}</p>
  </div>
</section>

<!-- Features strip -->
<!-- Sub-services -->
<section class="sv-list">
  <div class="sv-container">
    <p class="sv-list__eyebrow reveal">Nos services</p>
    <h2 class="sv-list__title reveal">Choisissez votre accompagnement</h2>

    <div class="sv-list__items stagger">
      {service.subServices.map(sub => (
        <a href={getLocalePath(lang, `/activites/${sub.slug}/`)} class="sv-card reveal">
          <div class="sv-card__image">
            <img src={sub.image} alt={sub.title} loading="lazy" />
            {sub.premium && <span class="sv-card__badge">Service premium</span>}
          </div>
          <div class="sv-card__body">
            <h3 class="sv-card__title">{sub.title}</h3>
            <p class="sv-card__desc">{sub.desc}</p>
            <div class="sv-card__meta">
              <span class="sv-card__meta-item">
                <svg viewBox="0 0 20 20" fill="none" width="14" height="14"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M10 6.5V10l3 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                {sub.duration}
              </span>
              <span class="sv-card__meta-sep">|</span>
              <span class="sv-card__meta-item" set:html={typeIconMap[sub.typeIcon] + ' ' + sub.type} />
            </div>
          </div>
          <div class="sv-card__arrow">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </a>
      ))}
    </div>

    <!-- Help CTA -->
    <a href={getLocalePath(lang, '/contact/')} class="sv-help">
      <div class="sv-help__icon">
        <svg viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="10" stroke="currentColor" stroke-width="1.4"/><path d="M11 11a3 3 0 015.5 1.5c0 2-3 2-3 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><circle cx="14" cy="20" r="1" fill="currentColor"/></svg>
      </div>
      <div class="sv-help__text">
        <strong>Besoin d'aide pour choisir ?</strong>
        <span>Nos conseillers sont disponibles pour vous guider.</span>
      </div>
      <div class="sv-help__arrow">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
    </a>
  </div>
</section>

</BaseLayout>

<style is:global>
  /* ============================================================
     SERVICE DETAIL PAGE
     ============================================================ */

  .sv-container { max-width: 800px; margin: 0 auto; padding: 0 24px; }

  /* ---- HERO ---- */
  .sv-hero {
    position: relative;
    overflow: hidden;
    min-height: 420px;
    display: flex;
    align-items: flex-end;
  }

  .sv-hero__bg {
    position: absolute;
    inset: 0;
  }

  .sv-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
  }

  .sv-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(12,58,40,0.3) 0%, rgba(12,58,40,0.75) 60%, rgba(12,58,40,0.92) 100%);
  }

  .sv-hero__content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
    padding: 120px 24px 60px;
    width: 100%;
  }

  .sv-hero__back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    color: #FAF8F4;
    position: absolute;
    top: 100px;
    left: 24px;
    transition: background 0.2s;
    text-decoration: none;
  }

  .sv-hero__back:hover {
    background: rgba(255,255,255,0.22);
    color: #FAF8F4;
  }

  .sv-hero__eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    color: #CBA96A;
    margin-bottom: 12px;
  }

  .sv-hero__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 3.2rem;
    font-weight: 700;
    color: #FAF8F4;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  .sv-hero__sub {
    font-family: 'Jost', sans-serif;
    font-size: 0.95rem;
    font-weight: 300;
    color: rgba(250,248,244,0.78);
    line-height: 1.7;
    max-width: 480px;
  }


  @media (max-width: 639px) {
    .sv-hero { min-height: 360px; }
    .sv-hero__title { font-size: 2.2rem; }
    .sv-hero__content { padding: 100px 24px 50px; }
    .sv-hero__back { top: 80px; }
  }

  /* ---- FEATURES STRIP ---- */
  .sv-features {
    background: #F7F7F7;
    padding: 32px 0;
  }

  .sv-features__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .sv-feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 20px 12px;
    background: #FFFFFF;
    border: 1px solid #EBE8E0;
    border-radius: 12px;
    text-align: center;
  }

  .sv-feature__icon {
    width: 36px;
    height: 36px;
    color: #14513A;
  }

  .sv-feature__icon svg {
    width: 100%;
    height: 100%;
  }

  .sv-feature__label {
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: #1C1C1A;
    line-height: 1.3;
  }

  @media (max-width: 639px) {
    .sv-features__grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ---- SUB-SERVICES LIST ---- */
  .sv-list {
    background: #FFFFFF;
    padding: 48px 0 80px;
  }

  .sv-list__eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: #14513A;
    margin-bottom: 8px;
  }

  .sv-list__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.8rem;
    font-weight: 600;
    color: #1C1C1A;
    margin-bottom: 32px;
  }

  .sv-list__items {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }

  /* ---- SERVICE CARD ---- */
  .sv-card {
    display: grid;
    grid-template-columns: 160px 1fr 48px;
    align-items: center;
    background: #FFFFFF;
    border: 1px solid #EBE8E0;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s;
  }

  .sv-card.reveal {
    transition: opacity 0.8s var(--ease-out-expo),
                transform 0.6s var(--ease-out-expo),
                box-shadow 0.4s var(--ease-out-quart),
                border-color 0.4s var(--ease-out-quart);
  }
  .sv-card:hover {
    transform: translateY(-4px);
    border-color: rgba(20,81,58,0.22);
    box-shadow: 0 18px 44px rgba(20,81,58,0.12);
    color: inherit;
  }

  .sv-card__image {
    position: relative;
    height: 100%;
    min-height: 140px;
    overflow: hidden;
  }

  .sv-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out-quart);
  }

  .sv-card:hover .sv-card__image img {
    transform: scale(1.06);
  }

  .sv-card__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 4px 10px;
    background: rgba(185,151,82,0.9);
    backdrop-filter: blur(4px);
    color: #FFFFFF;
    font-family: 'Jost', sans-serif;
    font-size: 0.58rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-radius: 4px;
  }

  .sv-card__body {
    padding: 20px 20px;
  }

  .sv-card__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1C1C1A;
    margin-bottom: 6px;
    line-height: 1.2;
  }

  .sv-card__desc {
    font-family: 'Jost', sans-serif;
    font-size: 0.8rem;
    font-weight: 300;
    color: #6B6B64;
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .sv-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: #1C1C1A;
  }

  .sv-card__meta-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: #6B6B64;
  }

  .sv-card__meta-item svg {
    color: #14513A;
    flex-shrink: 0;
  }

  .sv-card__meta-sep {
    color: #D4D0C8;
  }

  .sv-card__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 100%;
    color: #14513A;
    border-left: 1px solid #EBE8E0;
    transition: background 0.3s var(--ease-out-quart);
  }

  .sv-card:hover .sv-card__arrow {
    background: rgba(20,81,58,0.05);
  }
  .sv-card__arrow svg {
    transition: transform 0.35s var(--ease-spring);
  }
  .sv-card:hover .sv-card__arrow svg {
    transform: translateX(4px);
  }

  @media (max-width: 639px) {
    .sv-card {
      grid-template-columns: 120px 1fr 40px;
    }
    .sv-card__image { min-height: 120px; }
    .sv-card__body { padding: 14px 14px; }
    .sv-card__title { font-size: 1.05rem; }
    .sv-card__desc { font-size: 0.75rem; margin-bottom: 8px; }
  }

  /* ---- HELP CTA ---- */
  .sv-help {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: #14513A;
    border-radius: 16px;
    text-decoration: none;
    color: #FAF8F4;
    transition: background 0.2s, transform 0.25s;
  }

  .sv-help:hover {
    background: #1A6B4E;
    transform: translateY(-2px);
    color: #FAF8F4;
  }

  .sv-help__icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    color: #CBA96A;
  }

  .sv-help__icon svg {
    width: 100%;
    height: 100%;
  }

  .sv-help__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sv-help__text strong {
    font-family: 'Jost', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #FAF8F4;
  }

  .sv-help__text span {
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    font-weight: 300;
    color: rgba(250,248,244,0.65);
  }

  .sv-help__arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(203,169,106,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #CBA96A;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s;
  }

  .sv-help:hover .sv-help__arrow {
    background: rgba(203,169,106,0.15);
    border-color: #CBA96A;
  }
</style>
