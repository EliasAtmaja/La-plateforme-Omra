---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, getLocalePath } from '../../i18n/ui';
import { services } from '../../data/services';

const lang = getLangFromUrl(Astro.url);
const service = services.find(s => s.slug === 'visa')!;
---

<BaseLayout title={service.title} description={service.subtitle}>

<!-- Hero -->
<section class="sv-hero">
  <div class="sv-hero__bg">
    <img src={service.heroImage} alt="" loading="eager" />
  </div>
  <div class="sv-hero__overlay"></div>
  <a href={getLocalePath(lang, '/')} class="sv-hero__back" aria-label="Retour">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>
  <div class="sv-hero__content">
    <p class="sv-hero__eyebrow load-rise" style="--load-delay: 100ms">{service.eyebrow}</p>
    <h1 class="sv-hero__title load-rise" style="--load-delay: 250ms">{service.title}</h1>
    <p class="sv-hero__sub load-rise" style="--load-delay: 400ms">{service.subtitle}</p>
  </div>
</section>

<!-- Intro -->
<section class="pl-intro">
  <div class="pl-container">
    <p class="pl-intro__eyebrow reveal">Vos d&eacute;marches simplifi&eacute;es</p>
    <h2 class="pl-intro__title reveal">Nous vous accompagnons pour l'obtention de votre visa</h2>
    <p class="pl-intro__text reveal">
      Pour entrer en Arabie Saoudite, un visa est indispensable. Les d&eacute;marches peuvent sembler
      complexes : formulaires, documents, d&eacute;lais&hellip; Notre &eacute;quipe vous accompagne de A &agrave; Z
      pour l'obtention de votre visa, afin que vous puissiez pr&eacute;parer votre voyage l'esprit tranquille.
    </p>
    <p class="pl-intro__text reveal">
      Choisissez le type de visa qui correspond &agrave; votre voyage, remplissez le formulaire,
      et notre &eacute;quipe s'occupe du reste.
    </p>
  </div>
</section>

<!-- Choix du visa -->
<section class="vs-choice-section">
  <div class="pl-container">
    <div class="vs-choices reveal" id="visa-choices">
      <button type="button" class="vs-choice" data-visa-type="Visa Omra">
        <span class="vs-choice__icon">
          <svg viewBox="0 0 32 32" fill="none" width="32" height="32"><path d="M16 3l3 9h-6l3-9z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><rect x="9" y="14" width="14" height="13" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M13 27v-6a3 3 0 016 0v6" stroke="currentColor" stroke-width="1.4"/></svg>
        </span>
        <span class="vs-choice__title">Visa Omra</span>
        <span class="vs-choice__desc">Pour accomplir votre Omra &agrave; La Mecque et visiter M&eacute;dine.</span>
        <span class="vs-choice__cta">Choisir ce visa</span>
      </button>
      <button type="button" class="vs-choice" data-visa-type="Visa Touriste">
        <span class="vs-choice__icon">
          <svg viewBox="0 0 32 32" fill="none" width="32" height="32"><circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.4"/><path d="M4 16h24M16 4c3.5 3.5 5 7.5 5 12s-1.5 8.5-5 12c-3.5-3.5-5-7.5-5-12s1.5-8.5 5-12z" stroke="currentColor" stroke-width="1.4"/></svg>
        </span>
        <span class="vs-choice__title">Visa Touriste</span>
        <span class="vs-choice__desc">Pour d&eacute;couvrir l'Arabie Saoudite et ses richesses.</span>
        <span class="vs-choice__cta">Choisir ce visa</span>
      </button>
    </div>
  </div>
</section>

<!-- Formulaire -->
<section class="pl-form-section">
  <div class="pl-container">
    <form class="pl-form is-hidden" id="visa-form" novalidate>
      <p class="vs-form__chosen">
        Visa choisi : <strong id="visa-chosen-label"></strong>
        <button type="button" class="vs-form__change" id="visa-change">Changer</button>
      </p>
      <h3 class="pl-form__title">Vos informations</h3>

      <div class="pl-form__field">
        <label for="vs-name">Nom &amp; Pr&eacute;nom</label>
        <input type="text" id="vs-name" name="name" required autocomplete="name" />
      </div>

      <div class="pl-form__row">
        <div class="pl-form__field">
          <label for="vs-country">Pays d'origine</label>
          <input type="text" id="vs-country" name="country" required autocomplete="country-name" />
        </div>
        <div class="pl-form__field">
          <label for="vs-passport">Num&eacute;ro de passeport</label>
          <input type="text" id="vs-passport" name="passport" required autocomplete="off" />
        </div>
      </div>

      <div class="pl-form__row">
        <div class="pl-form__field">
          <label for="vs-arrival">Date d'arriv&eacute;e en Arabie Saoudite</label>
          <input type="date" id="vs-arrival" name="arrival" required />
        </div>
        <div class="pl-form__field">
          <label for="vs-departure">Date de d&eacute;part de l'Arabie Saoudite</label>
          <input type="date" id="vs-departure" name="departure" required />
        </div>
      </div>

      <p class="pl-form__error is-hidden" id="visa-error">Merci de remplir tous les champs correctement.</p>

      <button type="submit" class="pl-form__submit">
        Envoyer ma demande
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </form>

    <div class="pl-success is-hidden" id="visa-success">
      <div class="pl-success__icon">
        <svg viewBox="0 0 48 48" fill="none" width="48" height="48"><circle cx="24" cy="24" r="21" stroke="currentColor" stroke-width="2"/><path d="M15 24.5l6.5 6.5L33 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <h3 class="pl-success__title">Demande envoy&eacute;e !</h3>
      <p class="pl-success__text">
        Merci d'avoir fait confiance &agrave; notre agence, notre &eacute;quipe prendra contact
        avec vous dans les prochaines 24&nbsp;heures&nbsp;!
      </p>
      <a href={getLocalePath(lang, '/')} class="pl-success__home">
        Retour &agrave; l'accueil
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase';

  const choices = document.getElementById('visa-choices');
  const form = document.getElementById('visa-form') as HTMLFormElement | null;
  const success = document.getElementById('visa-success');
  const errorMsg = document.getElementById('visa-error');
  const chosenLabel = document.getElementById('visa-chosen-label');
  const changeBtn = document.getElementById('visa-change');
  let visaType = '';

  document.querySelectorAll('[data-visa-type]').forEach(btn => {
    btn.addEventListener('click', () => {
      visaType = (btn as HTMLElement).dataset.visaType!;
      if (chosenLabel) chosenLabel.textContent = visaType;
      choices?.classList.add('is-hidden');
      form?.classList.remove('is-hidden');
      form?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  changeBtn?.addEventListener('click', () => {
    form?.classList.add('is-hidden');
    choices?.classList.remove('is-hidden');
    choices?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  if (form && success) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        errorMsg?.classList.remove('is-hidden');
        return;
      }
      errorMsg?.classList.add('is-hidden');

      const submitBtn = form.querySelector('.pl-form__submit') as HTMLButtonElement;
      submitBtn.disabled = true;

      const data = new FormData(form);
      const { error } = await supabase.from('visa_requests').insert({
        visa_type: visaType,
        name: data.get('name'),
        country: data.get('country'),
        passport: data.get('passport'),
        arrival: data.get('arrival') || null,
        departure: data.get('departure') || null,
      });
      submitBtn.disabled = false;

      if (error) {
        if (errorMsg) {
          errorMsg.textContent = "Une erreur est survenue lors de l'envoi. Veuillez réessayer.";
          errorMsg.classList.remove('is-hidden');
        }
        return;
      }

      form.classList.add('is-hidden');
      success.classList.remove('is-hidden');
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>

<style is:global>
  .is-hidden { display: none !important; }

  .pl-container { max-width: 680px; margin: 0 auto; padding: 0 24px; }

  /* ---- HERO ---- */
  .sv-hero {
    position: relative;
    overflow: hidden;
    min-height: 420px;
    display: flex;
    align-items: flex-end;
  }
  .sv-hero__bg { position: absolute; inset: 0; }
  .sv-hero__bg img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center 60%;
  }
  .sv-hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(12,58,40,0.12) 0%, rgba(12,58,40,0.45) 60%, rgba(12,58,40,0.72) 100%);
  }
  .sv-hero__content {
    position: relative; z-index: 2;
    max-width: 800px; margin: 0 auto;
    padding: 120px 24px 60px; width: 100%;
  }
  .sv-hero__back {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 50%;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    color: #FAF8F4;
    position: absolute; top: 20px; left: 24px; z-index: 3;
    transition: background 0.2s;
    text-decoration: none;
  }
  .sv-hero__back:hover { background: rgba(255,255,255,0.22); color: #FAF8F4; }
  .sv-hero__eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.26em;
    color: #CBA96A; margin-bottom: 12px;
  }
  .sv-hero__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 3.2rem; font-weight: 700;
    color: #FAF8F4; line-height: 1.05; letter-spacing: -0.01em;
    margin-bottom: 16px; text-transform: uppercase;
  }
  .sv-hero__sub {
    font-family: 'Jost', sans-serif;
    font-size: 0.95rem; font-weight: 300;
    color: rgba(250,248,244,0.78); line-height: 1.7;
    max-width: 480px;
  }

  /* ---- INTRO ---- */
  .pl-intro {
    background: #FFFFFF;
    padding: 56px 0 8px;
  }
  .pl-intro__eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 0.7rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.22em;
    color: #B99752; margin: 0 0 8px;
  }
  .pl-intro__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.9rem; font-weight: 700;
    color: #14513A; line-height: 1.15;
    margin: 0 0 20px;
  }
  .pl-intro__text {
    font-family: 'Jost', sans-serif;
    font-size: 0.95rem; font-weight: 300;
    color: #4A4A42; line-height: 1.8;
    margin: 0 0 16px;
  }

  /* ---- CHOIX DU VISA ---- */
  .vs-choice-section {
    background: #FFFFFF;
    padding: 24px 0 0;
  }
  .vs-choices {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .vs-choice {
    display: flex; flex-direction: column; align-items: flex-start;
    gap: 10px;
    padding: 30px 26px;
    background: #FAF8F4;
    border: 1px solid #EFEDE6;
    border-radius: 20px;
    text-align: left;
    cursor: pointer;
    transition: transform 0.35s var(--ease-out-quart),
                border-color 0.35s var(--ease-out-quart),
                box-shadow 0.35s var(--ease-out-quart);
  }
  .vs-choice:hover {
    transform: translateY(-4px);
    border-color: rgba(20,81,58,0.3);
    box-shadow: 0 18px 40px rgba(20,81,58,0.12);
  }
  .vs-choice__icon { color: #B99752; }
  .vs-choice__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.45rem; font-weight: 700;
    color: #14513A;
    text-transform: uppercase;
  }
  .vs-choice__desc {
    font-family: 'Jost', sans-serif;
    font-size: 0.85rem; font-weight: 300;
    color: #6B6B63; line-height: 1.6;
  }
  .vs-choice__cta {
    margin-top: 8px;
    display: inline-block;
    padding: 10px 20px;
    background: #14513A; color: #FAF8F4;
    border-radius: 8px;
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase;
    transition: background 0.25s;
  }
  .vs-choice:hover .vs-choice__cta { background: #0C3A28; }

  /* ---- FORMULAIRE ---- */
  .pl-form-section {
    background: #FFFFFF;
    padding: 32px 0 88px;
  }
  .pl-form {
    background: #FAF8F4;
    border: 1px solid #EFEDE6;
    border-radius: 20px;
    padding: 36px 32px;
  }
  .vs-form__chosen {
    display: flex; align-items: center; gap: 8px;
    font-family: 'Jost', sans-serif;
    font-size: 0.85rem; font-weight: 300; color: #6B6B63;
    margin: 0 0 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid #EFEDE6;
  }
  .vs-form__chosen strong { color: #14513A; font-weight: 600; }
  .vs-form__change {
    margin-left: auto;
    background: none; border: none;
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem; font-weight: 500;
    color: #B99752; text-decoration: underline;
    cursor: pointer;
    padding: 0;
  }
  .vs-form__change:hover { color: #14513A; }
  .pl-form__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.4rem; font-weight: 700;
    color: #1C1C1A; margin: 0 0 24px;
  }
  .pl-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .pl-form__field { margin-bottom: 18px; }
  .pl-form__field label {
    display: block;
    font-family: 'Jost', sans-serif;
    font-size: 0.78rem; font-weight: 500;
    color: #1C1C1A;
    margin-bottom: 6px;
  }
  .pl-form__field input {
    width: 100%;
    padding: 12px 14px;
    background: #FFFFFF;
    border: 1px solid #E3E0D6;
    border-radius: 10px;
    font-family: 'Jost', sans-serif;
    font-size: 0.9rem; font-weight: 300;
    color: #1C1C1A;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .pl-form__field input:focus {
    outline: none;
    border-color: #14513A;
    box-shadow: 0 0 0 3px rgba(20,81,58,0.1);
  }
  .pl-form__error {
    font-family: 'Jost', sans-serif;
    font-size: 0.8rem; font-weight: 400;
    color: #B3261E;
    margin: 0 0 14px;
  }
  .pl-form__submit {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 30px;
    background: #14513A; color: #FAF8F4;
    border: none; border-radius: 10px;
    font-family: 'Jost', sans-serif;
    font-size: 0.82rem; font-weight: 500;
    letter-spacing: 0.05em; text-transform: uppercase;
    cursor: pointer;
    transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .pl-form__submit:hover {
    background: #0C3A28;
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(20,81,58,0.25);
  }
  .pl-form__submit svg { transition: transform 0.3s var(--ease-spring); }
  .pl-form__submit:hover svg { transform: translateX(4px); }

  /* ---- SUCCÈS ---- */
  .pl-success {
    text-align: center;
    background: #FAF8F4;
    border: 1px solid #EFEDE6;
    border-radius: 20px;
    padding: 56px 32px;
    animation: plSuccessIn 0.6s var(--ease-out-expo);
  }
  @keyframes plSuccessIn {
    from { opacity: 0; transform: translateY(16px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .pl-success__icon {
    color: #14513A;
    margin-bottom: 16px;
    display: inline-block;
  }
  .pl-success__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.7rem; font-weight: 700;
    color: #14513A; margin: 0 0 12px;
  }
  .pl-success__text {
    font-family: 'Jost', sans-serif;
    font-size: 0.95rem; font-weight: 300;
    color: #4A4A42; line-height: 1.8;
    max-width: 440px; margin: 0 auto;
  }
  .pl-success__home {
    display: inline-flex; align-items: center; gap: 10px;
    margin-top: 28px;
    padding: 13px 28px;
    background: #14513A; color: #FAF8F4;
    border-radius: 10px;
    font-family: 'Jost', sans-serif;
    font-size: 0.8rem; font-weight: 500;
    letter-spacing: 0.05em; text-transform: uppercase;
    text-decoration: none;
    transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .pl-success__home:hover {
    background: #0C3A28; color: #FAF8F4;
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(20,81,58,0.25);
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 639px) {
    .sv-hero { min-height: 360px; }
    .sv-hero__title { font-size: 2.2rem; }
    .sv-hero__content { padding: 100px 24px 50px; }
    .sv-hero__back { top: 80px; }

    .pl-intro { padding: 40px 0 4px; }
    .pl-intro__title { font-size: 1.5rem; }
    .pl-intro__text { font-size: 0.88rem; }

    .vs-choices { grid-template-columns: 1fr; gap: 14px; }
    .vs-choice { padding: 24px 20px; }

    .pl-form-section { padding: 24px 0 64px; }
    .pl-form { padding: 26px 18px; }
    .pl-form__row { grid-template-columns: 1fr; gap: 0; }
    .pl-form__submit { width: 100%; justify-content: center; }
    .pl-success { padding: 44px 20px; }
  }
</style>
