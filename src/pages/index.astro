---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, t, getLocalePath } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
---

<BaseLayout title={t(lang, 'nav.home')} description={t(lang, 'hero.subtitle')} hasHero={true}>

<!-- ========== HERO ========== -->
<section class="hm-hero">
  <div class="hm-hero__bg" aria-hidden="true">
    <img src="/assets/images/hero-mecca.png" alt="" loading="eager" />
  </div>
  <div class="hm-hero__content">
    <p class="hm-hero__pre load-rise" style="--load-delay: 150ms">La plateforme</p>
    <div class="hm-hero__title-wrap load-rise" style="--load-delay: 300ms">
      <span class="hm-hero__line-bar"></span>
      <h1 class="hm-hero__title">OMRA</h1>
      <span class="hm-hero__line-bar"></span>
    </div>
    <p class="hm-hero__sub load-rise" style="--load-delay: 450ms">Première plateforme française de mise en relation<br/><strong>entre les invités d'Allah et professionnels</strong></p>
    <a href="#services" class="hm-hero__cta load-rise" style="--load-delay: 700ms">
      <span>Choisir mon / ma guide</span>
      <span class="hm-hero__cta-arrow" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </a>
  </div>
</section>

<!-- ========== INTRO STATEMENT ========== -->
<section class="hm-intro">
  <div class="hm-container">
    <div class="hm-intro__icon reveal-scale" aria-hidden="true">
      <img src="/assets/images/intro-icon.png" alt="" class="hm-intro__icon-img" />
    </div>
    <div class="hm-intro__eyebrow-wrap reveal">
      <span class="hm-intro__line-bar"></span>
      <span class="hm-intro__eyebrow">En toute liberté</span>
      <span class="hm-intro__line-bar"></span>
    </div>
    <h2 class="hm-intro__title reveal">Votre accompagnement</h2>
    <p class="hm-intro__script reveal-blur">Sur mesure</p>
    <!-- Stepper bar -->
    <div class="hm-stepper" id="hm-stepper">
      <div class="hm-stepper__track">
        <div class="hm-stepper__line">
          <div class="hm-stepper__line-fill" id="stepper-fill"></div>
        </div>
        <div class="hm-stepper__node" data-step="1">
          <div class="hm-stepper__circle"><span>1</span></div>
        </div>
        <div class="hm-stepper__diamond" data-between="1-2"></div>
        <div class="hm-stepper__node" data-step="2">
          <div class="hm-stepper__circle"><span>2</span></div>
        </div>
        <div class="hm-stepper__diamond" data-between="2-3"></div>
        <div class="hm-stepper__node" data-step="3">
          <div class="hm-stepper__circle"><span>3</span></div>
        </div>
      </div>
      <div class="hm-stepper__captions" aria-live="polite">
        <p class="hm-step-text" data-step="1">Choisissez votre accompagnement</p>
        <p class="hm-step-text" data-step="2">Choisissez le guide et la date souhaitée</p>
        <p class="hm-step-text" data-step="3">Voyagez quand vous le désirez</p>
      </div>
    </div>

    <span class="hm-intro__end-line reveal-line" aria-hidden="true"></span>
  </div>
</section>

<!-- ========== 4 SERVICES ========== -->
<section class="hm-services" id="services">
  <div class="hm-container">
    <header class="hm-section-head hm-section-head--services reveal">
      <p class="hm-eyebrow hm-eyebrow--lined">S&eacute;lectionner vos accompagnements<span class="hm-eyebrow__script">&agrave; la carte</span></p>
    </header>

    <!-- Clip-path for curved panel edge -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <clipPath id="xpCurve" clipPathUnits="objectBoundingBox">
          <path d="M0,0 H0.85 C0.92,0.15 0.98,0.35 0.98,0.5 C0.98,0.65 0.92,0.85 0.85,1 H0 Z"/>
        </clipPath>
      </defs>
    </svg>

    <div class="xp__grid stagger">
      <!-- 01 — Planification -->
      <div class="xp__card reveal" data-xp-card style="--i:0">
        <div class="xp__visual">
          <img src="/assets/images/planification-bg.png" alt="Planification Omra" class="xp__img" loading="lazy" />
          <span class="xp__veil" aria-hidden="true"></span>
          <span class="xp__frame" aria-hidden="true"></span>
        </div>
        <div class="xp__panel">
          <span class="xp__sub">Organisation</span>
          <span class="xp__title">📞 Conseils &amp; Optimisation : Votre appel priv&eacute;</span>
          <span class="xp__reveal">
            <span class="xp__desc">Un entretien privé de 30 minutes avec un expert pour structurer votre séjour, éviter les pièges logistiques et maîtriser votre budget.</span>
            <a href={getLocalePath(lang, '/services/planification/')} class="xp__cta">
              <span>Découvrir</span>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </span>
        </div>
        <div class="xp__open" aria-hidden="true">
          <span class="xp__open-sub">Organisation</span>
          <span class="xp__open-title">📞 Conseils &amp; Optimisation : Votre appel priv&eacute;</span>
          <span class="xp__open-line"></span>
          <p class="xp__open-desc">Un entretien privé de 30 minutes avec un expert pour structurer votre séjour, éviter les pièges logistiques et maîtriser votre budget.</p>
          <a href={getLocalePath(lang, '/services/planification/')} class="xp__open-cta" aria-label="Découvrir : Planification">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <a href={getLocalePath(lang, '/services/planification/')} class="xp__img-cta" aria-label="Découvrir : Planification">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- 02 — Visas & Formalités -->
      <div class="xp__card reveal" data-xp-card style="--i:1">
        <div class="xp__visual">
          <img src="/assets/images/visa-bg.png" alt="Visas et formalités" class="xp__img" loading="lazy" />
          <span class="xp__veil" aria-hidden="true"></span>
          <span class="xp__frame" aria-hidden="true"></span>
        </div>
        <div class="xp__panel">
          <span class="xp__sub">Administratif</span>
          <span class="xp__title">Visas &amp; Formalit&eacute;s</span>
          <span class="xp__reveal">
            <span class="xp__desc">Nous vous accompagnons dans toutes vos démarches administratives pour l'obtention de votre visa.</span>
            <a href={getLocalePath(lang, '/services/visa/')} class="xp__cta">
              <span>Découvrir</span>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </span>
        </div>
        <div class="xp__open" aria-hidden="true">
          <span class="xp__open-sub">Administratif</span>
          <span class="xp__open-title">Visas &amp; Formalit&eacute;s</span>
          <span class="xp__open-line"></span>
          <p class="xp__open-desc">Nous vous accompagnons dans toutes vos démarches administratives pour l'obtention de votre visa.</p>
          <a href={getLocalePath(lang, '/services/visa/')} class="xp__open-cta" aria-label="Découvrir : Visas et formalités">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <a href={getLocalePath(lang, '/services/visa/')} class="xp__img-cta" aria-label="Découvrir : Visas et formalités">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- 03 — Makkah -->
      <div class="xp__card reveal" data-xp-card style="--i:2">
        <div class="xp__visual">
          <img src="/assets/images/makkah-bg.jpg" alt="Services à Makkah" class="xp__img" style="object-position: center 65%;" loading="lazy" />
          <span class="xp__veil" aria-hidden="true"></span>
          <span class="xp__frame" aria-hidden="true"></span>
        </div>
        <div class="xp__panel">
          <span class="xp__sub">Makkah</span>
          <span class="xp__title">Vos accompagnements à Makkah Al Mukaramah</span>
          <span class="xp__reveal">
            <span class="xp__desc">Accompagnement Omra complet, visite des lieux historiques sacrés et Omra depuis le Masjid Aïcha.</span>
            <a href={getLocalePath(lang, '/services/makkah/')} class="xp__cta">
              <span>Découvrir</span>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </span>
        </div>
        <div class="xp__open" aria-hidden="true">
          <span class="xp__open-sub">Makkah</span>
          <span class="xp__open-title">Vos accompagnements à Makkah Al Mukaramah</span>
          <span class="xp__open-line"></span>
          <p class="xp__open-desc">Accompagnement Omra complet, visite des lieux historiques sacrés et Omra depuis le Masjid Aïcha.</p>
          <a href={getLocalePath(lang, '/services/makkah/')} class="xp__open-cta" aria-label="Découvrir : Makkah">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <a href={getLocalePath(lang, '/services/makkah/')} class="xp__img-cta" aria-label="Découvrir : Makkah">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- 04 — Madinah -->
      <div class="xp__card reveal" data-xp-card style="--i:3">
        <div class="xp__visual">
          <img src="/assets/images/madinah-bg.jpg" alt="Services à al Madinah" class="xp__img" style="object-position: center 82%;" loading="lazy" />
          <span class="xp__veil" aria-hidden="true"></span>
          <span class="xp__frame" aria-hidden="true"></span>
        </div>
        <div class="xp__panel">
          <span class="xp__sub">Al Madinah</span>
          <span class="xp__title">Vos accompagnements à Al-Madinah</span>
          <span class="xp__reveal">
            <span class="xp__desc">Visite historique guidée, découverte du Masjid An-Nabawi, sorties shopping et accompagnement spirituel.</span>
            <a href={getLocalePath(lang, '/services/madinah/')} class="xp__cta">
              <span>Découvrir</span>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </span>
        </div>
        <div class="xp__open" aria-hidden="true">
          <span class="xp__open-sub">Al Madinah</span>
          <span class="xp__open-title">Vos accompagnements à Al-Madinah</span>
          <span class="xp__open-line"></span>
          <p class="xp__open-desc">Visite historique guidée, découverte du Masjid An-Nabawi, sorties shopping et accompagnement spirituel.</p>
          <a href={getLocalePath(lang, '/services/madinah/')} class="xp__open-cta" aria-label="Découvrir : Madinah">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <a href={getLocalePath(lang, '/services/madinah/')} class="xp__img-cta" aria-label="Découvrir : Madinah">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>

    </div>
  </div>
</section>

<!-- ========== REJOIGNEZ-NOUS ========== -->
<section class="hm-join">
  <div class="hm-join__wrap">
    <div class="hm-container">
      <div class="hm-join__inner reveal">
        <div class="hm-join__content">
          <p class="hm-join__eyebrow">Rejoignez-nous</p>
          <h2 class="hm-join__title">Devenez guide certifi&eacute;</h2>
          <p class="hm-join__text">Envie de devenir guide certifi&eacute; et proposer votre expertise aux invit&eacute;s d'Allah&nbsp;? Faites-nous en part en remplissant le formulaire ci-dessous&nbsp;!</p>
          <a href={getLocalePath(lang, '/rejoindre/')} class="hm-join__btn">
            Je souhaite vous rejoindre
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="hm-join__icon" aria-hidden="true">
          <svg viewBox="0 0 80 80" fill="none" width="80" height="80"><circle cx="40" cy="28" r="12" stroke="currentColor" stroke-width="2"/><path d="M18 68c0-12.2 9.8-22 22-22s22 9.8 22 22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M52 28l8 8M60 28l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ========== QUI SOMMES-NOUS ========== -->
<section class="hm-about">
  <div class="hm-about__wrap">
    <div class="hm-container">
      <div class="hm-about__grid reveal">
        <div class="hm-about__content">
          <p class="hm-about__eyebrow">Qui sommes-nous</p>
          <h2 class="hm-about__title">Plus de 10 ans d'expertise au service de votre s&eacute;r&eacute;nit&eacute;</h2>
          <p class="hm-about__text">La Plateforme Omra est le premier espace digital francophone qui connecte directement les invit&eacute;s d'Allah avec des professionnels locaux certifi&eacute;s. Nous ne vendons pas de voyages&nbsp;: nous mettons notre expertise &agrave; votre service pour vous guider physiquement et spirituellement une fois arriv&eacute; &agrave; destination.</p>
          <p class="hm-about__text">Forts de plus de 10 ann&eacute;es de pr&eacute;sence continue en Arabie Saoudite et ayant accompagn&eacute; plus de 10&nbsp;000 p&egrave;lerins, nous connaissons le terrain dans ses moindres d&eacute;tails. Chaque professionnel est rigoureusement s&eacute;lectionn&eacute; pour ses comp&eacute;tences, sa ma&icirc;trise du terrain et sa connaissance des rites.</p>
          <div class="hm-about__points">
            <div class="hm-about__point">
              <svg viewBox="0 0 20 20" fill="none" width="18" height="18"><path d="M4 10l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Accompagnement Omra pas &agrave; pas</span>
            </div>
            <div class="hm-about__point">
              <svg viewBox="0 0 20 20" fill="none" width="18" height="18"><path d="M4 10l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Visites historiques &agrave; Makkah et M&eacute;dine</span>
            </div>
            <div class="hm-about__point">
              <svg viewBox="0 0 20 20" fill="none" width="18" height="18"><path d="M4 10l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Assistance WhatsApp tout au long du s&eacute;jour</span>
            </div>
            <div class="hm-about__point">
              <svg viewBox="0 0 20 20" fill="none" width="18" height="18"><path d="M4 10l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Professionnels v&eacute;rifi&eacute;s et certifi&eacute;s</span>
            </div>
          </div>
          <a href={getLocalePath(lang, '/a-propos/')} class="hm-about__link">
            En savoir plus
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ========== STATS BAR ========== -->
<section class="hm-stats">
  <div class="hm-container">
    <div class="hm-stats__grid stagger">
      <div class="hm-stats__item reveal">
        <div class="hm-stats__icon" aria-hidden="true">
          <svg viewBox="0 0 28 28" fill="none"><path d="M14 3l10 4v7c0 6.5-4.3 12.3-10 15.2C8.3 26.3 4 20.5 4 14V7l10-4z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M9.5 14l3 3 6-6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div>
          <span class="hm-stats__value">Certifi&eacute; ✓</span>
          <span class="hm-stats__label">professionnels v&eacute;rifi&eacute;s</span>
        </div>
      </div>
      <div class="hm-stats__item reveal">
        <div class="hm-stats__icon" aria-hidden="true">
          <svg viewBox="0 0 28 28" fill="none"><circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="1.4"/><circle cx="18" cy="10" r="4" stroke="currentColor" stroke-width="1.4"/><path d="M3 24c0-4 3-7 7-7M25 24c0-4-3-7-7-7M10 17h8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        </div>
        <div>
          <span class="hm-stats__value">10K+</span>
          <span class="hm-stats__label">p&egrave;lerins accompagn&eacute;s</span>
        </div>
      </div>
      <div class="hm-stats__item reveal">
        <div class="hm-stats__icon" aria-hidden="true">
          <svg viewBox="0 0 28 28" fill="none"><path d="M14 3C7.9 3 3 7.9 3 14s4.9 11 11 11 11-4.9 11-11S20.1 3 14 3z" stroke="currentColor" stroke-width="1.4"/><path d="M10 17a6 6 0 0010-1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="10" cy="12" r="1.2" fill="currentColor"/><circle cx="18" cy="12" r="1.2" fill="currentColor"/></svg>
        </div>
        <div>
          <span class="hm-stats__value">7j/7</span>
          <span class="hm-stats__label">support d&eacute;di&eacute;</span>
        </div>
      </div>
      <div class="hm-stats__item reveal">
        <div class="hm-stats__icon" aria-hidden="true">
          <svg viewBox="0 0 28 28" fill="none"><path d="M14 3l3.5 7.5L25 12l-5.5 5 1.3 7.5L14 21l-6.8 3.5L8.5 17 3 12l7.5-1.5L14 3z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
        </div>
        <div>
          <span class="hm-stats__value">4.9/5</span>
          <span class="hm-stats__label">satisfaction client</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ========== TESTIMONIALS ========== -->
<section class="hm-testi" id="avis">
  <div class="hm-container">
    <header class="hm-section-head reveal">
      <p class="hm-eyebrow">Témoignages</p>
      <h2 class="hm-title">Ce que disent nos <em>pèlerins</em></h2>
    </header>

    <!-- Desktop: horizontal track with arrows -->
    <div class="hm-testi__track-wrap">
      <button class="hm-testi__arrow hm-testi__arrow--prev" id="testi-prev" aria-label="Précédent">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div class="hm-testi__track" id="testi-track"></div>
      <button class="hm-testi__arrow hm-testi__arrow--next" id="testi-next" aria-label="Suivant">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <!-- Empty state -->
    <p class="hm-testi__empty" id="testi-empty" hidden>Aucun avis pour le moment.</p>

    <!-- Mobile pagination dots -->
    <div class="hm-testi__dots" id="testi-dots"></div>

    <!-- Formulaire "Laisser un avis" -->
    <div class="hm-testi__form-wrap" id="review-form-wrap">
      <button class="hm-testi__toggle-form" id="toggle-review-form">
        <span>Laisser un avis</span>
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <form class="hm-testi__form" id="review-form" hidden>
        <div class="hm-testi__form-row">
          <label class="hm-testi__label">
            Votre prénom
            <input type="text" class="hm-testi__input" id="review-name" required />
          </label>
          <label class="hm-testi__label" id="review-service-label">
            Service utilisé
            <input type="text" class="hm-testi__input" id="review-service" required />
          </label>
        </div>
        <label class="hm-testi__guide-check">
          <input type="checkbox" id="review-is-guide" />
          <span>Cet avis concerne un guide</span>
        </label>
        <label class="hm-testi__label" id="review-guide-label" style="display:none">
          Choisissez le guide
          <select class="hm-testi__input" id="review-guide">
            <option value="">— Choisir un guide —</option>
          </select>
        </label>
        <label class="hm-testi__label">
          Note
          <div class="hm-testi__star-input" id="star-input">
            <button type="button" data-star="1" aria-label="1 étoile">★</button>
            <button type="button" data-star="2" aria-label="2 étoiles">★</button>
            <button type="button" data-star="3" aria-label="3 étoiles">★</button>
            <button type="button" data-star="4" aria-label="4 étoiles">★</button>
            <button type="button" data-star="5" aria-label="5 étoiles">★</button>
          </div>
        </label>
        <label class="hm-testi__label">
          Votre avis
          <textarea class="hm-testi__textarea" id="review-text" required rows="4"></textarea>
        </label>
        <button type="submit" class="hm-testi__submit">Envoyer mon avis</button>
        <p class="hm-testi__form-note">Votre avis sera visible après validation par notre équipe.</p>
      </form>
    </div>
  </div>
</section>

<!-- ========== CTA ========== -->
<section class="hm-cta">
  <div class="hm-container hm-cta__inner reveal">
    <p class="hm-cta__eyebrow">Pr&ecirc;t &agrave; partir&nbsp;?</p>
