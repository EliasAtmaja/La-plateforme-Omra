</style>

<script>
  import { supabase, mapReview } from '../lib/supabase';

  document.querySelectorAll('[data-xp-card]').forEach(card => {
    card.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a')) return;
      const wasExpanded = card.classList.contains('is-expanded');
      document.querySelectorAll('[data-xp-card]').forEach(c => {
        c.classList.remove('is-expanded');
        c.setAttribute('aria-expanded', 'false');
        const openEl = c.querySelector('.xp__open');
        if (openEl) openEl.setAttribute('aria-hidden', 'true');
      });
      if (!wasExpanded) {
        card.classList.add('is-expanded');
        card.setAttribute('aria-expanded', 'true');
        const openEl = card.querySelector('.xp__open');
        if (openEl) openEl.setAttribute('aria-hidden', 'false');
      }
    });
  });

  // ===== TESTIMONIALS =====
  const track = document.getElementById('testi-track');
  const prevBtn = document.getElementById('testi-prev');
  const nextBtn = document.getElementById('testi-next');
  const dotsWrap = document.getElementById('testi-dots');
  const emptyMsg = document.getElementById('testi-empty');
  let scrollPos = 0;
  let mobilePage = 0;
  const MOBILE_PER_PAGE = 3;

  function esc(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function isMobile() { return window.innerWidth <= 639; }
  function getCardsPerView() {
    if (window.innerWidth <= 639) return 1;
    if (window.innerWidth <= 1023) return 2;
    return 3;
  }
  function getAllCards() {
    return track ? Array.from(track.querySelectorAll('.hm-testi__card')) as HTMLElement[] : [];
  }
  // Avis chargés depuis Supabase (la RLS ne renvoie que les approuvés)
  let REVIEWS_HOME: any[] = [];
  function getApprovedReviews() {
    return REVIEWS_HOME;
  }
  async function loadReviews() {
    // Uniquement les avis généraux : ceux liés à un guide vivent sur sa fiche
    const { data } = await supabase.from('reviews').select('*')
      .is('guide_id', null)
      .order('created_at', { ascending: false });
    REVIEWS_HOME = (data || []).map(mapReview);
  }

  function renderReviews() {
    if (!track) return;
    const reviews = getApprovedReviews();
    track.innerHTML = '';
    scrollPos = 0;
    track.style.transform = '';

    if (reviews.length === 0) {
      if (emptyMsg) emptyMsg.hidden = false;
      if (dotsWrap) dotsWrap.innerHTML = '';
      return;
    }
    if (emptyMsg) emptyMsg.hidden = true;

    reviews.forEach((r: any) => {
      const starStr = '★'.repeat(r.stars) + '☆'.repeat(5 - r.stars);
      const card = document.createElement('div');
      card.className = 'hm-testi__card';
      card.innerHTML = `
        <div class="hm-testi__stars" aria-label="${r.stars} étoiles">${starStr}</div>
        <div class="hm-testi__text-wrap">
          <p class="hm-testi__text">${esc(r.text)}</p>
        </div>
        <div class="hm-testi__author">
          <span class="hm-testi__name">${esc(r.name)}</span>
          <span class="hm-testi__detail">${esc(r.service)}</span>
        </div>
      `;
      track.appendChild(card);
    });

    setupReadMore();
    if (isMobile()) {
      setupMobile();
    } else {
      getAllCards().forEach(c => c.classList.add('is-mobile-visible'));
    }
  }

  // Desktop scroll
  function scrollTrack(dir: number) {
    if (!track) return;
    const cards = getAllCards();
    if (!cards.length) return;
    const cardW = cards[0].offsetWidth + 24;
    const perView = getCardsPerView();
    const maxScroll = Math.max(0, (cards.length - perView) * cardW);
    scrollPos = Math.max(0, Math.min(scrollPos + dir * cardW, maxScroll));
    track.style.transform = `translateX(-${scrollPos}px)`;
    track.style.transition = 'transform 0.5s cubic-bezier(0.33, 1, 0.68, 1)';
  }

  prevBtn?.addEventListener('click', () => scrollTrack(-1));
  nextBtn?.addEventListener('click', () => scrollTrack(1));

  // Mobile pagination
  function setupMobile() {
    const cards = getAllCards();
    const totalPages = Math.ceil(cards.length / MOBILE_PER_PAGE);
    if (dotsWrap) {
      dotsWrap.innerHTML = '';
      for (let i = 0; i < totalPages; i++) {
        const dot = document.createElement('button');
        dot.className = 'hm-testi__dot';
        dot.textContent = String(i + 1);
        dot.setAttribute('aria-label', `Page ${i + 1}`);
        dot.addEventListener('click', () => showMobilePage(i));
        dotsWrap.appendChild(dot);
      }
    }
    showMobilePage(0);
  }

  function showMobilePage(page: number) {
    const cards = getAllCards();
    const totalPages = Math.ceil(cards.length / MOBILE_PER_PAGE);
    mobilePage = Math.max(0, Math.min(page, totalPages - 1));
    const start = mobilePage * MOBILE_PER_PAGE;
    const end = start + MOBILE_PER_PAGE;
    cards.forEach((c, i) => c.classList.toggle('is-mobile-visible', i >= start && i < end));
    dotsWrap?.querySelectorAll('.hm-testi__dot').forEach((d, i) =>
      d.classList.toggle('is-active', i === mobilePage)
    );
  }

  // "Lire plus" truncation
  function setupReadMore() {
    getAllCards().forEach(card => {
      const text = card.querySelector('.hm-testi__text') as HTMLElement;
      const wrap = card.querySelector('.hm-testi__text-wrap') as HTMLElement;
      if (!text || !wrap || wrap.querySelector('.hm-testi__read-more')) return;
      const btn = document.createElement('button');
      btn.className = 'hm-testi__read-more';
      btn.textContent = 'Lire plus';
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const expanded = text.classList.toggle('is-expanded');
        btn.textContent = expanded ? 'Réduire' : 'Lire plus';
      });
      wrap.appendChild(btn);
      requestAnimationFrame(() => {
        if (text.scrollHeight > text.clientHeight + 2) btn.classList.add('is-visible');
      });
    });
  }

  // Star rating input
  const starInput = document.getElementById('star-input');
  let selectedStars = 5;
  if (starInput) {
    const starBtns = starInput.querySelectorAll('button');
    starBtns.forEach(b => {
      const val = parseInt(b.getAttribute('data-star') || '0');
      b.addEventListener('click', () => {
        selectedStars = val;
        starBtns.forEach(s => {
          const sv = parseInt(s.getAttribute('data-star') || '0');
          s.classList.toggle('is-active', sv <= val);
        });
      });
      b.classList.add('is-active');
    });
  }

  // Toggle form
  const toggleBtn = document.getElementById('toggle-review-form');
  const reviewForm = document.getElementById('review-form') as HTMLFormElement;
  toggleBtn?.addEventListener('click', () => {
    if (!reviewForm) return;
    const isHidden = reviewForm.hidden;
    reviewForm.hidden = !isHidden;
    const icon = toggleBtn.querySelector('svg');
    if (icon) icon.style.transform = isHidden ? 'rotate(45deg)' : '';
  });

  // Avis pour un guide : case à cocher + liste des guides (synchronisée avec la base)
  const isGuideCheck = document.getElementById('review-is-guide') as HTMLInputElement | null;
  const guideLabel = document.getElementById('review-guide-label') as HTMLElement | null;
  const guideSelect = document.getElementById('review-guide') as HTMLSelectElement | null;
  const serviceLabel = document.getElementById('review-service-label') as HTMLElement | null;
  const serviceInput = document.getElementById('review-service') as HTMLInputElement | null;
  let guidesLoaded = false;

  async function loadGuidesList() {
    if (guidesLoaded || !guideSelect) return;
    const { data } = await supabase.from('guides').select('id, first_name, last_name').order('first_name');
    guideSelect.innerHTML = '<option value="">— Choisir un guide —</option>' +
      (data || []).map((g: any) => `<option value="${g.id}">${esc(g.first_name)} ${esc(g.last_name)}</option>`).join('');
    guidesLoaded = true;
  }

  isGuideCheck?.addEventListener('change', () => {
    const forGuide = isGuideCheck.checked;
    if (guideLabel) guideLabel.style.display = forGuide ? '' : 'none';
    if (serviceLabel) serviceLabel.style.display = forGuide ? 'none' : '';
    if (serviceInput) serviceInput.required = !forGuide;
    if (forGuide) loadGuidesList();
  });

  // Submit review → Supabase (statut « en attente », modéré par l'admin)
  reviewForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = (document.getElementById('review-name') as HTMLInputElement).value.trim();
    const text = (document.getElementById('review-text') as HTMLTextAreaElement).value.trim();
    const forGuide = !!isGuideCheck?.checked;
    const guideId = forGuide ? (guideSelect?.value || '') : '';

    if (forGuide && !guideId) {
      alert('Veuillez choisir le guide concerné par votre avis.');
      return;
    }
    const guideName = forGuide && guideSelect
      ? guideSelect.options[guideSelect.selectedIndex].textContent || ''
      : '';
    const service = forGuide ? `Guide - ${guideName}` : (serviceInput?.value.trim() || '');
    if (!name || !text || !service) return;

    const { error } = await supabase.from('reviews').insert({
      name,
      service,
      text,
      stars: selectedStars,
      status: 'pending',
      guide_id: forGuide ? guideId : null,
    });
    if (error) {
      alert("Une erreur est survenue lors de l'envoi de votre avis. Veuillez réessayer.");
      return;
    }

    // Reset form & show confirmation
    reviewForm.reset();
    reviewForm.hidden = true;
    if (guideLabel) guideLabel.style.display = 'none';
    if (serviceLabel) serviceLabel.style.display = '';
    if (serviceInput) serviceInput.required = true;
    const icon = toggleBtn?.querySelector('svg');
    if (icon) (icon as HTMLElement).style.transform = '';
    selectedStars = 5;
    starInput?.querySelectorAll('button').forEach(b => b.classList.add('is-active'));

    const formWrap = document.getElementById('review-form-wrap');
    if (formWrap) {
      const success = document.createElement('div');
      success.className = 'hm-testi__form-success';
      success.innerHTML = '<p>Merci ! Votre avis a été envoyé et sera publié après validation.</p>';
      formWrap.appendChild(success);
      setTimeout(() => success.remove(), 5000);
    }
  });

  // Init + resize
  loadReviews().then(renderReviews);
  window.addEventListener('resize', () => {
    if (isMobile()) {
      setupMobile();
      if (track) track.style.transform = '';
    } else {
      getAllCards().forEach(c => c.classList.add('is-mobile-visible'));
      scrollPos = 0;
      if (track) track.style.transform = '';
    }
  });

  // ---- Stepper scroll animation (smooth) ----
  (function() {
    const stepper = document.getElementById('hm-stepper');
    if (!stepper) return;

    const nodes = stepper.querySelectorAll('.hm-stepper__node') as NodeListOf<HTMLElement>;
    const diamonds = stepper.querySelectorAll('.hm-stepper__diamond') as NodeListOf<HTMLElement>;
    const fill = document.getElementById('stepper-fill') as HTMLElement;
    const texts = document.querySelectorAll('.hm-step-text') as NodeListOf<HTMLElement>;
    const introSection = stepper.closest('.hm-intro') as HTMLElement;
    if (!introSection) return;

    let currentStep = -1;
    let currentFill = 0;
    let targetFill = 0;
    let rafId = 0;

    function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

    function setStep(step: number) {
      if (step === currentStep) return;
      currentStep = step;
      nodes.forEach((node, i) => {
        const s = i + 1;
        node.classList.remove('is-active', 'is-done');
        if (s < step) node.classList.add('is-done');
        else if (s === step) node.classList.add('is-active');
      });
      texts.forEach(t => {
        const s = parseInt(t.dataset.step || '0');
        t.classList.toggle('is-lit', s === step);
      });
      diamonds.forEach((d, i) => {
        d.classList.toggle('is-on', (i + 1) < step);
      });
    }

    let lastT = 0;
    function tick(now: number) {
      const dt = lastT ? Math.min((now - lastT) / 1000, 0.05) : 1 / 60;
      lastT = now;
      // Frame-rate-independent exponential smoothing — silky at any refresh rate
      const alpha = 1 - Math.exp(-dt * 5);
      currentFill = lerp(currentFill, targetFill, alpha);
      if (Math.abs(currentFill - targetFill) < 0.05) currentFill = targetFill;
      fill.style.width = currentFill + '%';
      if (currentFill !== targetFill) rafId = requestAnimationFrame(tick);
      else { rafId = 0; lastT = 0; }
    }

    function setFill(pct: number) {
      targetFill = pct;
      if (!rafId) rafId = requestAnimationFrame(tick);
    }

    function onScroll() {
      const rect = introSection.getBoundingClientRect();
      const viewH = window.innerHeight;

      if (rect.top > viewH) { setStep(0); setFill(0); return; }
      if (rect.bottom < 0) { setStep(3); setFill(100); return; }

      const progress = 1 - (rect.bottom / (viewH + rect.height));

      if (progress < 0.45) {
        setStep(0);
        setFill(0);
      } else if (progress < 0.58) {
        setStep(1);
        const local = (progress - 0.45) / 0.13;
        setFill(local * 45);
      } else if (progress < 0.72) {
        setStep(2);
        const local = (progress - 0.58) / 0.14;
        setFill(45 + local * 45);
      } else {
        setStep(3);
        setFill(100);
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
