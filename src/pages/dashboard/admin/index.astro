---
import '../../../styles/global.css';
---

<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — La plateforme Omra</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="adm-body">

<!-- ====== LOGIN ====== -->
<div id="login-gate" class="adm-login">
  <div class="adm-login__card">
    <div class="adm-login__icon">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="5" y="12" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M9 12V9a5 5 0 0110 0v3" stroke="currentColor" stroke-width="1.6"/><circle cx="14" cy="18" r="2" fill="currentColor"/></svg>
    </div>
    <h1>Administration</h1>
    <p>Connectez-vous pour acceder au tableau de bord</p>
    <form id="login-form">
      <input type="email" id="login-email" placeholder="Email" autocomplete="username" required />
      <input type="password" id="login-pass" placeholder="Mot de passe" autocomplete="current-password" required />
      <button type="submit">Se connecter</button>
      <p class="adm-login__error is-hidden" id="login-error">Identifiants incorrects</p>
    </form>
  </div>
</div>

<!-- ====== DASHBOARD ====== -->
<div id="dashboard" class="adm is-hidden">

  <!-- Sidebar -->
  <aside class="adm-side">
    <div class="adm-side__brand">
      <svg width="18" height="18" viewBox="0 0 32 32" fill="none"><path d="M16 2L18.8 8.2L25.9 6.1L23.8 13.2L30 16L23.8 18.8L25.9 25.9L18.8 23.8L16 30L13.2 23.8L6.1 25.9L8.2 18.8L2 16L8.2 13.2L6.1 6.1L13.2 8.2L16 2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
      <span>Admin</span>
    </div>
    <nav class="adm-side__nav">
      <a href="#" class="adm-side__link adm-side__link--active" data-nav-tab="guides">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.4"/><path d="M2.5 14c0-3 2.5-5.5 5.5-5.5s5.5 2.5 5.5 5.5" stroke="currentColor" stroke-width="1.4"/></svg>
        Guides
        <span class="adm-side__badge adm-side__badge--red" id="refusal-count" hidden>0</span>
      </a>
      <a href="#" class="adm-side__link" data-nav-tab="reviews">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M14 6.5l-3.5 3.5-1.5-1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 3h12v10H2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M2 6h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
        Avis
        <span class="adm-side__badge" id="pending-count" hidden>0</span>
      </a>
    </nav>
    <button class="adm-side__logout" id="logout-btn">Deconnexion</button>
  </aside>

  <!-- Main -->
  <main class="adm-main">
    <div id="panel-guides-header">
      <header class="adm-top">
        <div>
          <h1 class="adm-top__title">Gestion des guides</h1>
          <p class="adm-top__sub">0 guides enregistres</p>
        </div>
        <button class="adm-add-btn" id="open-add-guide">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Ajouter
        </button>
      </header>
    </div>

    <!-- ====== REVIEWS PANEL ====== -->
    <div class="adm-reviews is-hidden" id="panel-reviews">
      <header class="adm-top">
        <div>
          <h1 class="adm-top__title">Gestion des avis</h1>
          <p class="adm-top__sub" id="reviews-sub"></p>
        </div>
      </header>

      <div class="adm-reviews__tabs">
        <button class="adm-reviews__tab adm-reviews__tab--active" data-rtab="pending">En attente <span id="rtab-pending-count"></span></button>
        <button class="adm-reviews__tab" data-rtab="approved">Approuvés <span id="rtab-approved-count"></span></button>
        <button class="adm-reviews__tab" data-rtab="rejected">Refusés <span id="rtab-rejected-count"></span></button>
      </div>

      <div class="adm-reviews__list" id="reviews-list"></div>
    </div>

    <!-- Guides list (rendered client-side from localStorage) -->
    <div class="adm-guides" id="panel-guides"></div>
  </main>
</div>

<!-- ====== ADD GUIDE MODAL ====== -->
<div class="adm-modal-overlay is-hidden" id="modal-overlay">
  <div class="adm-modal">
    <div class="adm-modal__header">
      <h2 id="modal-title">Ajouter un guide</h2>
      <button class="adm-modal__close" id="close-modal">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>
    <form id="add-guide-form">
      <div class="adm-modal__body">
        <div class="adm-form-photo">
          <!-- State 1: empty placeholder -->
          <div class="adm-form-photo__empty" id="photo-empty">
            <div class="adm-form-photo__placeholder" id="photo-placeholder">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="2" y="5" width="24" height="18" rx="3" stroke="currentColor" stroke-width="1.6"/><circle cx="10" cy="12" r="3" stroke="currentColor" stroke-width="1.4"/><path d="M26 19l-6-5.5-4 3.5-3.5-2.5L2 21" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>Photo du guide</span>
            </div>
            <button type="button" class="adm-form-photo__btn" id="photo-btn">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              Choisir une photo
            </button>
          </div>
          <input type="file" id="photo-input" accept="image/*" class="adm-form-photo__input" />

          <!-- State 2: crop editor -->
          <div class="adm-form-photo__editor is-hidden" id="photo-editor">
            <p class="adm-form-photo__editor-hint">Deplacez et zoomez pour ajuster</p>
            <div class="adm-form-photo__crop" id="photo-crop">
              <img id="photo-crop-img" src="" alt="" draggable="false" />
            </div>
            <div class="adm-form-photo__zoom">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/><path d="M10 10l3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M4 6h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              <input type="range" id="photo-zoom" min="100" max="300" value="100" />
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/><path d="M10 10l3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M4 6h4M6 4v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            </div>
            <div class="adm-form-photo__editor-actions">
              <button type="button" class="adm-form-photo__editor-cancel" id="photo-crop-cancel">Annuler</button>
              <button type="button" class="adm-form-photo__editor-confirm" id="photo-crop-confirm">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7.5L5.5 10L11 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Valider
              </button>
            </div>
          </div>

          <!-- State 3: validated result -->
          <div class="adm-form-photo__result is-hidden" id="photo-result">
            <div class="adm-form-photo__result-circle" id="photo-result-circle"></div>
            <button type="button" class="adm-form-photo__btn" id="photo-change-btn">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M10 7.5L7 4.5 4 7.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 4.5v7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              Changer la photo
            </button>
          </div>
        </div>
        <div class="adm-form-row">
          <div class="adm-form-field">
            <label>Prenom</label>
            <input type="text" name="prenom" required placeholder="Ahmed" />
          </div>
          <div class="adm-form-field">
            <label>Nom</label>
            <input type="text" name="nom" required placeholder="Al-Harbi" />
          </div>
        </div>
        <div class="adm-form-row">
          <div class="adm-form-field">
            <label>Ville</label>
            <select name="ville" required>
              <option value="">Choisir...</option>
              <option value="medina">Medine</option>
              <option value="mecca">La Mecque</option>
            </select>
          </div>
          <div class="adm-form-field">
            <label>Prix (€)</label>
            <input type="number" name="prix" min="1" required placeholder="150" />
          </div>
        </div>
        <div class="adm-form-field">
          <label>Diplome</label>
          <input type="text" name="diplome" placeholder="Licence en Histoire islamique" />
        </div>
        <div class="adm-form-field">
          <label>Langues (separees par des virgules)</label>
          <input type="text" name="langues" placeholder="Arabe, Francais, Anglais" />
        </div>
        <div class="adm-form-field">
          <label>Description</label>
          <textarea name="description" rows="4" placeholder="Presentez le guide en quelques lignes..."></textarea>
        </div>
        <div class="adm-form-separator"></div>
        <p class="adm-form-section-title">Identifiants de connexion</p>
        <div class="adm-form-row">
          <div class="adm-form-field">
            <label>Identifiant</label>
            <input type="text" name="identifiant" required placeholder="prenom.nom" />
          </div>
          <div class="adm-form-field">
            <label>Mot de passe</label>
            <input type="text" name="mdp" required placeholder="mot de passe" />
          </div>
        </div>
      </div>
      <div class="adm-modal__footer">
        <button type="button" class="adm-modal__cancel" id="cancel-modal">Annuler</button>
        <button type="submit" class="adm-modal__submit">Enregistrer</button>
      </div>
    </form>
  </div>
</div>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { supabase, SUPABASE_URL, SUPABASE_ANON_KEY, GUIDE_EMAIL_SUFFIX, isAdmin, mapGuide, mapBooking, mapReview } from '../../../lib/supabase';

  // Client secondaire : sert uniquement à créer les comptes guides
  // sans écraser la session admin en cours.
  const authClient = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
    auth: { persistSession: false, autoRefreshToken: false },
  });

  const gate = document.getElementById('login-gate')!;
  const dash = document.getElementById('dashboard')!;

  // ===== CACHES DE DONNÉES (chargés après connexion admin) =====
  let DB_GUIDES: any[] = [];
  let DB_BOOKINGS: any[] = [];
  let DB_REVIEWS: any[] = [];
  let DB_AVAIL: Record<string, string[]> = {};

  async function loadAll() {
    const [g, b, r, a] = await Promise.all([
      supabase.from('guides').select('*').order('created_at'),
      supabase.from('bookings').select('*').order('date'),
      supabase.from('reviews').select('*').order('created_at', { ascending: false }),
      supabase.from('availability').select('guide_id, date'),
    ]);
    DB_GUIDES = (g.data || []).map(mapGuide);
    DB_BOOKINGS = (b.data || []).map(mapBooking);
    DB_REVIEWS = (r.data || []).map(mapReview);
    DB_AVAIL = {};
    (a.data || []).forEach((row: any) => {
      (DB_AVAIL[row.guide_id] = DB_AVAIL[row.guide_id] || []).push(row.date);
    });
  }

  async function enterDashboard() {
    await loadAll();
    gate.classList.add('is-hidden');
    dash.classList.remove('is-hidden');
    reloadAllCards();
    updatePendingBadge();
    updateRefusalBadge();
  }

  // Session admin déjà active ?
  (async () => {
    if (await isAdmin()) await enterDashboard();
  })();

  document.getElementById('login-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('login-email') as HTMLInputElement).value.trim();
    const pass = (document.getElementById('login-pass') as HTMLInputElement).value;
    const errorEl = document.getElementById('login-error')!;
    errorEl.classList.add('is-hidden');

    const { error } = await supabase.auth.signInWithPassword({ email, password: pass });
    if (error || !(await isAdmin())) {
      await supabase.auth.signOut();
      errorEl.classList.remove('is-hidden');
      return;
    }
    await enterDashboard();
  });

  document.getElementById('logout-btn')!.addEventListener('click', async () => {
    await supabase.auth.signOut();
    gate.classList.remove('is-hidden');
    dash.classList.add('is-hidden');
  });

  // (All event handlers for guide cards are now wired in createAdminGuideCard)

  // Modal
  const overlay = document.getElementById('modal-overlay')!;

  // Photo crop editor
  const photoInput = document.getElementById('photo-input') as HTMLInputElement;
  const photoEmpty = document.getElementById('photo-empty')!;
  const photoEditor = document.getElementById('photo-editor')!;
  const photoResult = document.getElementById('photo-result')!;
  const photoCropImg = document.getElementById('photo-crop-img') as HTMLImageElement;
  const photoCrop = document.getElementById('photo-crop')!;
  const photoZoom = document.getElementById('photo-zoom') as HTMLInputElement;
  const photoResultCircle = document.getElementById('photo-result-circle')!;

  let cropState = { x: 0, y: 0, scale: 1, dragging: false, startX: 0, startY: 0, origX: 0, origY: 0, imgSrc: '' };

  function showPhotoState(state: 'empty' | 'editor' | 'result') {
    photoEmpty.classList.toggle('is-hidden', state !== 'empty');
    photoEditor.classList.toggle('is-hidden', state !== 'editor');
    photoResult.classList.toggle('is-hidden', state !== 'result');
  }

  function updateCropTransform() {
    photoCropImg.style.transform = `translate(${cropState.x}px, ${cropState.y}px) scale(${cropState.scale})`;
  }

  function clampPosition() {
    const cropSize = 160;
    const imgW = photoCropImg.naturalWidth * cropState.scale;
    const imgH = photoCropImg.naturalHeight * cropState.scale;
    const minX = cropSize - imgW;
    const minY = cropSize - imgH;
    cropState.x = Math.min(0, Math.max(minX, cropState.x));
    cropState.y = Math.min(0, Math.max(minY, cropState.y));
  }

  document.getElementById('photo-btn')!.addEventListener('click', () => photoInput.click());
  document.getElementById('photo-placeholder')!.addEventListener('click', () => photoInput.click());
  document.getElementById('photo-change-btn')!.addEventListener('click', () => photoInput.click());

  photoInput.addEventListener('change', () => {
    const file = photoInput.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (e) => {
      cropState.imgSrc = e.target?.result as string;
      photoCropImg.src = cropState.imgSrc;
      photoCropImg.onload = () => {
        const cropSize = 160;
        const minDim = Math.min(photoCropImg.naturalWidth, photoCropImg.naturalHeight);
        cropState.scale = cropSize / minDim;
        cropState.x = (cropSize - photoCropImg.naturalWidth * cropState.scale) / 2;
        cropState.y = (cropSize - photoCropImg.naturalHeight * cropState.scale) / 2;
        photoZoom.min = String(Math.round(cropState.scale * 100));
        photoZoom.max = String(Math.round(cropState.scale * 100 * 3));
        photoZoom.value = String(Math.round(cropState.scale * 100));
        updateCropTransform();
        showPhotoState('editor');
      };
    };
    reader.readAsDataURL(file);
  });

  // Drag to move
  photoCrop.addEventListener('mousedown', (e: MouseEvent) => {
    e.preventDefault();
    cropState.dragging = true;
    cropState.startX = e.clientX;
    cropState.startY = e.clientY;
    cropState.origX = cropState.x;
    cropState.origY = cropState.y;
    photoCrop.style.cursor = 'grabbing';
  });
  window.addEventListener('mousemove', (e: MouseEvent) => {
    if (!cropState.dragging) return;
    cropState.x = cropState.origX + (e.clientX - cropState.startX);
    cropState.y = cropState.origY + (e.clientY - cropState.startY);
    clampPosition();
    updateCropTransform();
  });
  window.addEventListener('mouseup', () => {
    cropState.dragging = false;
    photoCrop.style.cursor = 'grab';
  });

  // Touch support
  photoCrop.addEventListener('touchstart', (e: TouchEvent) => {
    if (e.touches.length !== 1) return;
    cropState.dragging = true;
    cropState.startX = e.touches[0].clientX;
    cropState.startY = e.touches[0].clientY;
    cropState.origX = cropState.x;
    cropState.origY = cropState.y;
  }, { passive: true });
  window.addEventListener('touchmove', (e: TouchEvent) => {
    if (!cropState.dragging || e.touches.length !== 1) return;
    cropState.x = cropState.origX + (e.touches[0].clientX - cropState.startX);
    cropState.y = cropState.origY + (e.touches[0].clientY - cropState.startY);
    clampPosition();
    updateCropTransform();
  }, { passive: true });
  window.addEventListener('touchend', () => { cropState.dragging = false; });

  // Zoom slider
  photoZoom.addEventListener('input', () => {
    const centerX = 80; const centerY = 80;
    const oldScale = cropState.scale;
    cropState.scale = parseInt(photoZoom.value) / 100;
    const ratio = cropState.scale / oldScale;
    cropState.x = centerX - (centerX - cropState.x) * ratio;
    cropState.y = centerY - (centerY - cropState.y) * ratio;
    clampPosition();
    updateCropTransform();
  });

  // Scroll to zoom
  photoCrop.addEventListener('wheel', (e: WheelEvent) => {
    e.preventDefault();
    const minScale = parseInt(photoZoom.min) / 100;
    const maxScale = parseInt(photoZoom.max) / 100;
    const delta = e.deltaY > 0 ? -0.05 : 0.05;
    const oldScale = cropState.scale;
    cropState.scale = Math.min(maxScale, Math.max(minScale, cropState.scale + delta));
    const ratio = cropState.scale / oldScale;
    cropState.x = 80 - (80 - cropState.x) * ratio;
    cropState.y = 80 - (80 - cropState.y) * ratio;
    clampPosition();
    photoZoom.value = String(Math.round(cropState.scale * 100));
    updateCropTransform();
  }, { passive: false });

  // Cancel crop
  document.getElementById('photo-crop-cancel')!.addEventListener('click', () => {
    showPhotoState('empty');
    photoInput.value = '';
  });

  // Confirm crop
  document.getElementById('photo-crop-confirm')!.addEventListener('click', () => {
    const canvas = document.createElement('canvas');
    const size = 320;
    canvas.width = size; canvas.height = size;
    const ctx = canvas.getContext('2d')!;
    const displayScale = size / 160;
    ctx.drawImage(
      photoCropImg,
      cropState.x * displayScale,
      cropState.y * displayScale,
      photoCropImg.naturalWidth * cropState.scale * displayScale,
      photoCropImg.naturalHeight * cropState.scale * displayScale
    );
    const dataUrl = canvas.toDataURL('image/jpeg', 0.9);
    photoResultCircle.style.backgroundImage = `url(${dataUrl})`;
    showPhotoState('result');
  });

  // ===== GUIDES & BOOKINGS (servis depuis les caches Supabase) =====
  function getStoredGuides(): any[] {
    return DB_GUIDES;
  }
  function getBookings(): any[] {
    return DB_BOOKINGS;
  }
  function getAvail(guideId: string): string[] {
    return DB_AVAIL[guideId] || [];
  }

  function escG(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  const admMonthNames = ['Janvier', 'Fevrier', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Aout', 'Septembre', 'Octobre', 'Novembre', 'Decembre'];
  const admDayLabels = ['Lu', 'Ma', 'Me', 'Je', 'Ve', 'Sa', 'Di'];

  function renderAdmMiniCal(container: HTMLElement, guideId: string, month: number, year: number) {
    const avail = new Set(getAvail(guideId));
    const bookedDates = new Set(getBookings().filter((b: any) => b.guideId === guideId && b.status !== 'reassigned').map((b: any) => b.date));
    const firstDay = new Date(year, month, 1).getDay();
    const offset = firstDay === 0 ? 6 : firstDay - 1;
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const today = new Date();

    let html = admDayLabels.map(d => `<span class="adm-cal__day-label">${d}</span>`).join('');
    for (let i = 0; i < offset; i++) html += '<span class="adm-cal__empty"></span>';
    for (let d = 1; d <= daysInMonth; d++) {
      const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
      const isBooked = bookedDates.has(dateStr);
      const isAvail = avail.has(dateStr);
      const isPast = new Date(year, month, d) < new Date(today.getFullYear(), today.getMonth(), today.getDate());
      let cls = 'adm-cal__day';
      if (isPast) cls += ' adm-cal__day--past';
      else if (isBooked) cls += ' adm-cal__day--booked';
      else if (isAvail) cls += ' adm-cal__day--avail';
      else cls += ' adm-cal__day--busy';
      html += `<span class="${cls}">${d}</span>`;
    }

    const grid = container.querySelector('.adm-cal__grid') as HTMLElement;
    const title = container.querySelector('.adm-cal__title') as HTMLElement;
    if (grid) grid.innerHTML = html;
    if (title) title.textContent = `${admMonthNames[month]} ${year}`;

    const nav = container.querySelector('[data-cal-nav]') as HTMLElement;
    if (nav) {
      nav.dataset.month = month.toString();
      nav.dataset.year = year.toString();
    }
  }

  function reloadAllCards() {
    const panel = document.getElementById('panel-guides')!;
    panel.innerHTML = '';
    getStoredGuides().forEach((g: any) => panel.appendChild(createAdminGuideCard(g)));
    updateGuideCount();
    updateRefusalBadge();
  }

  function createAdminGuideCard(g: any): HTMLElement {
    const villeLabel = g.city === 'medina' ? 'Medine' : 'La Mecque';
    const initials = (g.firstName?.[0] || '') + (g.lastName?.[0] || '');
    const avatarHtml = g.photo
      ? `<div class="adm-g__avatar adm-g__avatar--photo" style="background-image:url(${g.photo})"></div>`
      : `<div class="adm-g__avatar adm-g__avatar--${g.city}">${escG(initials)}</div>`;

    const allBookings = getBookings();
    const guideBookings = allBookings.filter((b: any) => b.guideId === g.id && b.status !== 'reassigned');
    const pendingRefusals = guideBookings.filter((b: any) => b.status === 'pending-refusal');
    const hasRefusal = pendingRefusals.length > 0;
    const hasBookings = guideBookings.length > 0;

    const card = document.createElement('div');
    card.className = 'adm-g';
    card.dataset.guideId = g.id;

    let notifHtml = '';
    if (hasRefusal) {
      notifHtml = `<div class="adm-g__notif">
        <button class="adm-g__dot adm-g__dot--red" data-toggle-refusal="${g.id}" title="Mission refusee — cliquez pour voir le motif">
          <span class="adm-g__dot-pulse"></span>
        </button>
      </div>`;
    } else {
      notifHtml = `<div class="adm-g__notif">
        <span class="adm-g__dot adm-g__dot--green" title="Aucun probleme"></span>
      </div>`;
    }

    let bookingBtnHtml = '';
    if (hasBookings) {
      bookingBtnHtml = `<button class="adm-g__booking-btn" data-toggle-bookings="${g.id}">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1" y="2" width="10" height="9" rx="1.5" stroke="currentColor" stroke-width="1.1"/><path d="M3.5 1v2M8.5 1v2M1 5h10" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
        Reservations
        <span class="adm-g__booking-count">${guideBookings.length}</span>
      </button>`;
    } else {
      bookingBtnHtml = `<span class="adm-g__status adm-g__status--free">Libre</span>`;
    }

    let bookingsPanelHtml = '';
    if (hasBookings) {
      const rows = guideBookings.map((b: any) => {
        const dateStr = b.date ? new Date(b.date + 'T00:00:00').toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) : b.dates || '';
        const statusLabel = b.status === 'pending-refusal'
          ? `<span class="adm-g__bk-status adm-g__bk-status--refused">Refus en attente</span>`
          : b.replacementOf
            ? `<span class="adm-g__bk-status adm-g__bk-status--replaced">En remplacement de ${escG(b.replacementOf)}</span>`
            : '';
        return `
          <div class="adm-g__bk-row" data-bk-row>
            <button class="adm-g__bk-summary" data-toggle-bk-detail>
              <div class="adm-g__bk-summary-left">
                <span class="adm-g__bk-client">${escG(b.clientName || b.client || 'Client')}</span>
                <span class="adm-g__bk-dates">${escG(dateStr)}${b.slot ? ' &middot; ' + escG(b.slot) : ''}</span>
                ${b.seen
                  ? '<span class="adm-g__bk-status adm-g__bk-status--seen">✓ Vu par le guide</span>'
                  : '<span class="adm-g__bk-status adm-g__bk-status--unseen">Non vu</span>'}
                ${b.activityName ? `<span class="adm-g__bk-status adm-g__bk-status--activity">${escG(b.activityName)}</span>` : ''}
                ${statusLabel}
              </div>
              <svg class="adm-g__bk-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 5.5L7 8.5L10 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="adm-g__bk-detail is-hidden">
              <div class="adm-g__bk-detail-grid">
                <div class="adm-g__bk-detail-item">
                  <span class="adm-g__bk-label">Telephone</span>
                  <span class="adm-g__bk-value">${escG(b.clientPhone || 'Non renseigne')}</span>
                </div>
                <div class="adm-g__bk-detail-item">
                  <span class="adm-g__bk-label">Email</span>
                  <span class="adm-g__bk-value">${escG(b.clientEmail || 'Non renseigne')}</span>
                </div>
              </div>
            </div>
          </div>
        `;
      }).join('');

      bookingsPanelHtml = `
        <div class="adm-g__bookings is-hidden" id="bookings-${g.id}">
          <div class="adm-g__bookings-header">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1.5" y="2.5" width="13" height="11.5" rx="2" stroke="currentColor" stroke-width="1.2"/><path d="M4.5 1v3M11.5 1v3M1.5 6.5h13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            <span>Reservations (${guideBookings.length})</span>
          </div>
          ${rows}
        </div>
      `;
    }

    let refusalPanelHtml = '';
    if (hasRefusal) {
      // Guides de remplacement : même ville, et tarif égal ou inférieur (jamais supérieur)
      const otherGuides = getStoredGuides().filter((og: any) =>
        og.id !== g.id
        && og.city === g.city
        && (og.pricePerDay || 0) <= (g.pricePerDay || 0)
      );
      const now = new Date();
      const curMonth = now.getMonth();
      const curYear = now.getFullYear();

      const refusalRows = pendingRefusals.map((refBooking: any, idx: number) => {
        const refDateStr = refBooking.date ? new Date(refBooking.date + 'T00:00:00').toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
        const reason = refBooking.refusalReason || '';
        const radioName = `replace-${g.id}-${refBooking.id}`;

        let replacementCards = '';
        if (otherGuides.length > 0) {
          replacementCards = otherGuides.map((r: any) => {
            const rInitials = (r.firstName?.[0] || '') + (r.lastName?.[0] || '');
            const rLangs = (r.languages || []).join(', ');
            const ogAvail = new Set(getAvail(r.id));
            const ogBooked = new Set(getBookings().filter((b: any) => b.guideId === r.id && b.status !== 'reassigned').map((b: any) => b.date));
            const isAvailable = refBooking.date ? (ogAvail.has(refBooking.date) && !ogBooked.has(refBooking.date)) : true;
            return `
              <div class="adm-g__rcard ${!isAvailable ? 'adm-g__rcard--unavailable' : ''}" data-rcard data-rcard-guide-id="${r.id}">
                <div class="adm-g__rcard-header" data-toggle-rcard>
                  <input type="radio" name="${radioName}" value="${r.id}" class="adm-g__rcard-radio" ${!isAvailable ? 'disabled' : ''} />
                  ${r.photo
                    ? `<div class="adm-g__replace-av adm-g__replace-av--photo" style="background-image:url(${r.photo})"></div>`
                    : `<div class="adm-g__replace-av adm-g__replace-av--${r.city}">${escG(rInitials)}</div>`}
                  <div class="adm-g__rcard-info">
                    <span class="adm-g__replace-name">${escG(r.firstName)} ${escG(r.lastName)}</span>
                    <span class="adm-g__replace-info">${r.pricePerDay ? r.pricePerDay + '€' : ''} ${rLangs ? '— ' + escG(rLangs) : ''}
                      ${!isAvailable ? '<span class="adm-g__rcard-unavail">Indisponible a cette date</span>' : '<span class="adm-g__rcard-avail">Disponible</span>'}
                    </span>
                  </div>
                  <svg class="adm-g__rcard-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 5.5L7 8.5L10 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="adm-g__rcard-body is-hidden">
                  <div class="adm-g__rcard-profile">
                    ${r.diploma ? `<div class="adm-g__rcard-detail"><span class="adm-g__rcard-label">Diplome</span><span class="adm-g__rcard-value">${escG(r.diploma)}</span></div>` : ''}
                    <a href="/guides/profil/?id=${r.id}" class="adm-g__rcard-profile-link">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M1 6s2-4 5-4 5 4 5 4-2 4-5 4-5-4-5-4z" stroke="currentColor" stroke-width="1.1"/><circle cx="6" cy="6" r="1.5" stroke="currentColor" stroke-width="1.1"/></svg>
                      Voir le profil complet
                    </a>
                  </div>
                  <div class="adm-cal">
                    <div class="adm-cal__header">
                      <span class="adm-cal__title">${admMonthNames[curMonth]} ${curYear}</span>
                      <div class="adm-cal__legend">
                        <span class="adm-cal__legend-item"><span class="adm-cal__dot adm-cal__dot--avail"></span>Disponible</span>
                        <span class="adm-cal__legend-item"><span class="adm-cal__dot adm-cal__dot--busy"></span>Indisponible</span>
                        <span class="adm-cal__legend-item"><span class="adm-cal__dot adm-cal__dot--booked"></span>Reserve</span>
                      </div>
                    </div>
                    <div class="adm-cal__grid"></div>
                    <div class="adm-cal__nav" data-cal-nav data-guide-id="${r.id}" data-month="${curMonth}" data-year="${curYear}">
                      <button class="adm-cal__nav-btn" data-cal-prev>
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M7.5 2.5L4 6l3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </button>
                      <button class="adm-cal__nav-btn" data-cal-next>
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4.5 2.5L8 6l-3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            `;
          }).join('');
        } else {
          replacementCards = `<p class="adm-g__no-replace">Aucun autre guide dans cette ville.</p>`;
        }

        return `
          <div class="adm-g__ref-row" data-ref-row>
            <button class="adm-g__ref-summary" data-toggle-ref-detail>
              <span class="adm-g__ref-dot"></span>
              <div class="adm-g__ref-summary-left">
                <span class="adm-g__ref-date">${escG(refDateStr)}</span>
                <span class="adm-g__ref-client">${escG(refBooking.clientName || 'Client non renseigne')}</span>
              </div>
              <svg class="adm-g__ref-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 5.5L7 8.5L10 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="adm-g__ref-detail is-hidden">
              <div class="adm-g__ref-reason">
                <span class="adm-g__ref-reason-label">Motif du refus :</span>
                <blockquote class="adm-g__refusal-msg">"${escG(reason)}"</blockquote>
              </div>
              <div class="adm-g__replace">
                <p class="adm-g__replace-label">Reassigner a un autre guide (optionnel) :</p>
                <div class="adm-g__replace-list">${replacementCards}</div>
              </div>
              <div class="adm-g__refusal-actions">
                <button class="adm-g__refusal-confirm" data-confirm-refusal="${g.id}" data-booking-id="${refBooking.id}" data-radio-name="${radioName}">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7.5L5.5 10L11 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Confirmer le refus
                </button>
              </div>
            </div>
          </div>
        `;
      }).join('');

      refusalPanelHtml = `
        <div class="adm-g__refusal" id="refusal-${g.id}">
          <div class="adm-g__refusal-header">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.4"/><path d="M9 5.5v4M9 12.5v.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <span>Refus en attente (${pendingRefusals.length})</span>
          </div>
          ${refusalRows}
        </div>
      `;
    }

    card.innerHTML = `
      ${notifHtml}
      ${avatarHtml}
      <div class="adm-g__info">
        <h3 class="adm-g__name">${escG(g.firstName)} ${escG(g.lastName)}</h3>
        <div class="adm-g__meta">
          <span class="adm-g__city adm-g__city--${g.city}">${escG(villeLabel)}</span>
          ${bookingBtnHtml}
        </div>
      </div>
      <div class="adm-g__actions">
        <button class="adm-g__btn adm-g__btn--outline" data-open-creds="${g.id}">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="2" y="6" width="10" height="6.5" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M4.5 6V4.5a2.5 2.5 0 015 0V6" stroke="currentColor" stroke-width="1.2"/></svg>
          Identifiants
        </button>
        <button class="adm-g__btn adm-g__btn--outline" data-edit-guide="${g.id}">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M8.5 2.5l3 3M2 8.5L9.5 1l3 3L5 11.5 1.5 12l.5-3.5z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Modifier
        </button>
        <a href="/guides/profil/?id=${g.id}&login=1" class="adm-g__btn adm-g__btn--outline">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7s2.5-5 6-5 6 5 6 5-2.5 5-6 5-6-5-6-5z" stroke="currentColor" stroke-width="1.2"/><circle cx="7" cy="7" r="2" stroke="currentColor" stroke-width="1.2"/></svg>
          Voir le profil
        </a>
        <button class="adm-g__btn adm-g__btn--outline adm-g__btn--danger" data-delete-guide="${g.id}">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 4h8M5.5 4V3a1 1 0 011-1h1a1 1 0 011 1v1M4.5 4v7a1.5 1.5 0 001.5 1.5h2a1.5 1.5 0 001.5-1.5V4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Supprimer
        </button>
      </div>
      ${bookingsPanelHtml}
      ${refusalPanelHtml}
      <div class="adm-g__creds is-hidden" id="creds-${g.id}">
        <h4>Identifiants de ${escG(g.firstName)} ${escG(g.lastName)}</h4>
        <div class="adm-g__creds-form">
          <div class="adm-g__creds-field">
            <label>Identifiant</label>
            <input type="text" value="${escG(g.login || '')}" readonly />
          </div>
          <p class="adm-g__creds-note">Le mot de passe est chiffr&eacute; et n'est plus visible.<br/>Pour le r&eacute;initialiser : Supabase &rarr; Authentication &rarr; Users.</p>
        </div>
      </div>
    `;

    // Wire up event handlers
    card.querySelector(`[data-open-creds="${g.id}"]`)!.addEventListener('click', () => {
      document.getElementById(`creds-${g.id}`)?.classList.toggle('is-hidden');
    });
    card.querySelector(`[data-delete-guide="${g.id}"]`)!.addEventListener('click', async () => {
      if (!confirm(`Supprimer ${g.firstName} ${g.lastName} ?`)) return;
      const { error } = await supabase.from('guides').delete().eq('id', g.id);
      if (error) { alert('Erreur lors de la suppression. Réessayez.'); return; }
      DB_GUIDES = DB_GUIDES.filter((x: any) => x.id !== g.id);
      card.remove();
      updateGuideCount();
    });
    card.querySelector(`[data-edit-guide="${g.id}"]`)!.addEventListener('click', () => {
      openEditModal(g.id);
    });

    // Toggle bookings
    const bookingsBtn = card.querySelector(`[data-toggle-bookings="${g.id}"]`);
    if (bookingsBtn) {
      bookingsBtn.addEventListener('click', () => {
        document.getElementById(`bookings-${g.id}`)?.classList.toggle('is-hidden');
      });
    }

    // Toggle booking detail rows
    card.querySelectorAll('[data-toggle-bk-detail]').forEach(btn => {
      btn.addEventListener('click', () => {
        const row = btn.closest('[data-bk-row]') as HTMLElement;
        if (!row) return;
        const detail = row.querySelector('.adm-g__bk-detail') as HTMLElement;
        const arrow = btn.querySelector('.adm-g__bk-arrow') as HTMLElement;
        if (detail) {
          const isOpen = !detail.classList.contains('is-hidden');
          detail.classList.toggle('is-hidden');
          if (arrow) arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
        }
      });
    });

    // Toggle refusal panel
    const refusalDot = card.querySelector(`[data-toggle-refusal="${g.id}"]`);
    if (refusalDot) {
      refusalDot.addEventListener('click', () => {
        document.getElementById(`refusal-${g.id}`)?.classList.toggle('is-hidden');
      });
    }

    // Replacement card toggles
    card.querySelectorAll('[data-toggle-rcard]').forEach(header => {
      header.addEventListener('click', () => {
        const rcard = header.closest('[data-rcard]') as HTMLElement;
        if (!rcard) return;
        const body = rcard.querySelector('.adm-g__rcard-body') as HTMLElement;
        const arrow = header.querySelector('.adm-g__rcard-arrow') as HTMLElement;
        if (body) {
          const isOpen = !body.classList.contains('is-hidden');
          body.classList.toggle('is-hidden');
          if (arrow) arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
        }
      });
    });

    // Render mini calendars for replacement guides
    card.querySelectorAll('.adm-cal').forEach(cal => {
      const nav = cal.querySelector('[data-cal-nav]') as HTMLElement;
      if (!nav) return;
      const rGuideId = nav.dataset.guideId!;
      const m = parseInt(nav.dataset.month!);
      const y = parseInt(nav.dataset.year!);
      renderAdmMiniCal(cal as HTMLElement, rGuideId, m, y);

      const prevBtn = cal.querySelector('[data-cal-prev]');
      const nextBtn = cal.querySelector('[data-cal-next]');
      if (prevBtn) prevBtn.addEventListener('click', () => {
        let cm = parseInt(nav.dataset.month!);
        let cy = parseInt(nav.dataset.year!);
        cm--; if (cm < 0) { cm = 11; cy--; }
        renderAdmMiniCal(cal as HTMLElement, rGuideId, cm, cy);
      });
      if (nextBtn) nextBtn.addEventListener('click', () => {
        let cm = parseInt(nav.dataset.month!);
        let cy = parseInt(nav.dataset.year!);
        cm++; if (cm > 11) { cm = 0; cy++; }
        renderAdmMiniCal(cal as HTMLElement, rGuideId, cm, cy);
      });
    });

    // Toggle refusal row accordions
    card.querySelectorAll('[data-toggle-ref-detail]').forEach(btn => {
      btn.addEventListener('click', () => {
        const row = btn.closest('[data-ref-row]') as HTMLElement;
        if (!row) return;
        const detail = row.querySelector('.adm-g__ref-detail') as HTMLElement;
        const arrow = btn.querySelector('.adm-g__ref-arrow') as HTMLElement;
        if (detail) {
          const isOpen = !detail.classList.contains('is-hidden');
          detail.classList.toggle('is-hidden');
          if (arrow) arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
        }
      });
    });

    // Radio selection on replacement cards
    card.querySelectorAll('.adm-g__rcard-radio').forEach(radio => {
      radio.addEventListener('click', (e) => {
        e.stopPropagation();
      });
    });

    // Confirm refusal buttons (one per refusal row)
    card.querySelectorAll('[data-confirm-refusal]').forEach(confirmBtn => {
      confirmBtn.addEventListener('click', async () => {
        const el = confirmBtn as HTMLElement;
        const bookingId = el.dataset.bookingId!;
        const radioName = el.dataset.radioName!;
        const selectedRadio = card.querySelector(`input[name="${radioName}"]:checked`) as HTMLInputElement | null;
        const toId = selectedRadio ? selectedRadio.value : null;

        const booking = getBookings().find((b: any) => b.id === bookingId);
        if (!booking) return;

        (el as HTMLButtonElement).disabled = true;

        const { error } = await supabase.from('bookings')
          .update({ status: 'reassigned' })
          .eq('id', bookingId);
        if (error) {
          (el as HTMLButtonElement).disabled = false;
          alert('Une erreur est survenue. Réessayez.');
          return;
        }

        if (toId) {
          const fromGuide = getStoredGuides().find((x: any) => x.id === g.id);
          const { error: insErr } = await supabase.from('bookings').insert({
            guide_id: toId,
            date: booking.date,
            slot: booking.slot || null,
            activity_slug: booking.activitySlug || null,
            activity_name: booking.activityName || null,
            client_name: booking.clientName || null,
            client_email: booking.clientEmail || null,
            client_phone: booking.clientPhone || null,
            status: 'confirmed',
            replacement_of: fromGuide ? `${fromGuide.firstName} ${fromGuide.lastName}` : null,
          });
          if (insErr) alert("Le refus a été confirmé, mais la réassignation a échoué (date déjà prise ?).");
        }

        await loadAll();
        reloadAllCards();
      });
    });

    return card;
  }

  function updateGuideCount() {
    const countEl = document.querySelector('.adm-top__sub');
    if (countEl) {
      const n = getStoredGuides().length;
      countEl.textContent = `${n} guide${n !== 1 ? 's' : ''} enregistre${n !== 1 ? 's' : ''}`;
    }
  }

  // ===== EDIT / CREATE MODE =====
  let editingGuideId: string | null = null;
  const modalTitle = document.getElementById('modal-title')!;
  const addGuideForm = document.getElementById('add-guide-form') as HTMLFormElement;

  function openEditModal(guideId: string) {
    const guide = getStoredGuides().find((g: any) => g.id === guideId);
    if (!guide) return;
    editingGuideId = guideId;
    modalTitle.textContent = 'Modifier le guide';

    (addGuideForm.querySelector('[name="prenom"]') as HTMLInputElement).value = guide.firstName || '';
    (addGuideForm.querySelector('[name="nom"]') as HTMLInputElement).value = guide.lastName || '';
    (addGuideForm.querySelector('[name="ville"]') as HTMLSelectElement).value = guide.city || '';
    (addGuideForm.querySelector('[name="prix"]') as HTMLInputElement).value = guide.pricePerDay ? String(guide.pricePerDay) : '';
    (addGuideForm.querySelector('[name="diplome"]') as HTMLInputElement).value = guide.diploma || '';
    (addGuideForm.querySelector('[name="langues"]') as HTMLInputElement).value = (guide.languages || []).join(', ');
    (addGuideForm.querySelector('[name="description"]') as HTMLTextAreaElement).value = guide.description || '';
    // Identifiants gérés par Supabase Auth : non modifiables après création
    const loginInput = addGuideForm.querySelector('[name="identifiant"]') as HTMLInputElement;
    const mdpInput = addGuideForm.querySelector('[name="mdp"]') as HTMLInputElement;
    loginInput.value = guide.login || '';
    loginInput.disabled = true;
    mdpInput.value = '';
    mdpInput.placeholder = 'Non modifiable ici';
    mdpInput.disabled = true;

    if (guide.photo) {
      photoResultCircle.style.backgroundImage = `url(${guide.photo})`;
      showPhotoState('result');
    } else {
      showPhotoState('empty');
    }

    overlay.classList.remove('is-hidden');
  }

  function resetModal() {
    editingGuideId = null;
    modalTitle.textContent = 'Ajouter un guide';
    addGuideForm.reset();
    const loginInput = addGuideForm.querySelector('[name="identifiant"]') as HTMLInputElement;
    const mdpInput = addGuideForm.querySelector('[name="mdp"]') as HTMLInputElement;
    loginInput.disabled = false;
    mdpInput.disabled = false;
    mdpInput.placeholder = 'mot de passe (6 caractères min.)';
    showPhotoState('empty');
    photoResultCircle.style.backgroundImage = '';
  }

  document.getElementById('open-add-guide')!.addEventListener('click', () => {
    resetModal();
    overlay.classList.remove('is-hidden');
  });
  document.getElementById('close-modal')!.addEventListener('click', () => { overlay.classList.add('is-hidden'); resetModal(); });
  document.getElementById('cancel-modal')!.addEventListener('click', () => { overlay.classList.add('is-hidden'); resetModal(); });
  overlay.addEventListener('click', (e) => { if (e.target === overlay) { overlay.classList.add('is-hidden'); resetModal(); } });

  addGuideForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = addGuideForm;
    const prenom = (form.querySelector('[name="prenom"]') as HTMLInputElement).value.trim();
    const nom = (form.querySelector('[name="nom"]') as HTMLInputElement).value.trim();
    const ville = (form.querySelector('[name="ville"]') as HTMLSelectElement).value;
    const prix = (form.querySelector('[name="prix"]') as HTMLInputElement).value;
    const diplome = (form.querySelector('[name="diplome"]') as HTMLInputElement).value.trim();
    const langues = (form.querySelector('[name="langues"]') as HTMLInputElement).value.trim();
    const description = (form.querySelector('[name="description"]') as HTMLTextAreaElement).value.trim();
    const identifiant = (form.querySelector('[name="identifiant"]') as HTMLInputElement).value.trim().toLowerCase();
    const mdp = (form.querySelector('[name="mdp"]') as HTMLInputElement).value;

    if (!prenom || !nom) return;

    const submitBtn = form.querySelector('.adm-modal__submit') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enregistrement...';
    const restoreBtn = () => { submitBtn.disabled = false; submitBtn.textContent = 'Enregistrer'; };

    const photoUrl = photoResultCircle.style.backgroundImage;
    const photoMatch = photoUrl.match(/url\("?([^"]*)"?\)/);
    let photoDataUrl = photoMatch ? photoMatch[1] : '';

    const fields = {
      first_name: prenom,
      last_name: nom,
      city: ville || 'medina',
      diploma: diplome || null,
      description: description || null,
      languages: langues ? langues.split(',').map((l: string) => l.trim()).filter(Boolean) : [],
      price_per_day: prix ? parseInt(prix) : 0,
    };

    if (editingGuideId) {
      // === UPDATE ===
      const existing = getStoredGuides().find((g: any) => g.id === editingGuideId);
      if (!existing) { restoreBtn(); return; }
      if (!photoDataUrl && existing.photo) photoDataUrl = existing.photo;

      const { data, error } = await supabase.from('guides')
        .update({ ...fields, photo: photoDataUrl || null })
        .eq('id', editingGuideId)
        .select()
        .single();
      restoreBtn();
      if (error || !data) { alert('Erreur lors de la mise à jour. Réessayez.'); return; }

      const updated = mapGuide(data);
      const idx = DB_GUIDES.findIndex((g: any) => g.id === editingGuideId);
      if (idx !== -1) DB_GUIDES[idx] = updated;

      const oldCard = document.querySelector(`[data-guide-id="${editingGuideId}"]`);
      if (oldCard) {
        const newCard = createAdminGuideCard(updated);
        oldCard.replaceWith(newCard);
        newCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    } else {
      // === CREATE : compte Auth (mot de passe chiffré) + fiche guide ===
      if (!identifiant || !/^[a-z0-9._-]+$/.test(identifiant)) {
        restoreBtn();
        alert("Identifiant invalide : lettres minuscules, chiffres, points, tirets uniquement (sans espaces ni accents).");
        return;
      }
      if (!mdp || mdp.length < 6) {
        restoreBtn();
        alert('Le mot de passe doit contenir au moins 6 caractères.');
        return;
      }

      const { data: signUpData, error: signUpErr } = await authClient.auth.signUp({
        email: identifiant + GUIDE_EMAIL_SUFFIX,
        password: mdp,
      });
      if (signUpErr || !signUpData.user) {
        restoreBtn();
        alert(`Impossible de créer le compte du guide : ${signUpErr?.message || 'erreur inconnue'}.\n(Identifiant déjà utilisé ?)`);
        return;
      }

      const { data, error } = await supabase.from('guides')
        .insert({
          ...fields,
          photo: photoDataUrl || null,
          login: identifiant,
          auth_user_id: signUpData.user.id,
        })
        .select()
        .single();
      restoreBtn();
      if (error || !data) { alert("Le compte a été créé mais l'enregistrement du guide a échoué. Réessayez."); return; }

      const created = mapGuide(data);
      DB_GUIDES.push(created);

      const panel = document.getElementById('panel-guides')!;
      const card = createAdminGuideCard(created);
      panel.appendChild(card);
      card.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    updateGuideCount();
    overlay.classList.add('is-hidden');
    resetModal();
  });

  // ===== TAB NAVIGATION (Guides / Avis) =====
  const navTabs = document.querySelectorAll('[data-nav-tab]');
  const guidesHeader = document.getElementById('panel-guides-header')!;
  const guidesPanel = document.getElementById('panel-guides')!;
  const reviewsPanel = document.getElementById('panel-reviews')!;

  navTabs.forEach(tab => {
    tab.addEventListener('click', (e) => {
      e.preventDefault();
      const target = (tab as HTMLElement).dataset.navTab;
      navTabs.forEach(t => t.classList.remove('adm-side__link--active'));
      tab.classList.add('adm-side__link--active');
      if (target === 'reviews') {
        guidesHeader.classList.add('is-hidden');
        guidesPanel.classList.add('is-hidden');
        reviewsPanel.classList.remove('is-hidden');
        renderAdminReviews();
      } else {
        guidesHeader.classList.remove('is-hidden');
        guidesPanel.classList.remove('is-hidden');
        reviewsPanel.classList.add('is-hidden');
      }
    });
  });

  // ===== REVIEWS ADMIN =====
  let activeRTab = 'pending';

  function getReviews() {
    return DB_REVIEWS;
  }

  async function setReviewStatus(id: string, status: string): Promise<boolean> {
    const { error } = await supabase.from('reviews').update({ status }).eq('id', id);
    if (error) { alert('Erreur, réessayez.'); return false; }
    const r = DB_REVIEWS.find((x: any) => x.id === id);
    if (r) r.status = status;
    return true;
  }

  function escHtml(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function updatePendingBadge() {
    const pending = getReviews().filter((r: any) => r.status === 'pending');
    const badge = document.getElementById('pending-count');
    if (badge) {
      badge.textContent = String(pending.length);
      badge.hidden = pending.length === 0;
    }
  }

  function updateRefusalBadge() {
    const refusals = getBookings().filter((b: any) => b.status === 'pending-refusal');
    const badge = document.getElementById('refusal-count');
    if (badge) {
      badge.textContent = String(refusals.length);
      badge.hidden = refusals.length === 0;
    }
  }

  function renderAdminReviews() {
    const all = getReviews();
    const pending = all.filter((r: any) => r.status === 'pending');
    const approved = all.filter((r: any) => r.status === 'approved');
    const rejected = all.filter((r: any) => r.status === 'rejected');

    const sub = document.getElementById('reviews-sub');
    if (sub) sub.textContent = `${all.length} avis au total — ${pending.length} en attente`;

    const pc = document.getElementById('rtab-pending-count');
    const ac = document.getElementById('rtab-approved-count');
    const rc = document.getElementById('rtab-rejected-count');
    if (pc) pc.textContent = pending.length > 0 ? `(${pending.length})` : '';
    if (ac) ac.textContent = approved.length > 0 ? `(${approved.length})` : '';
    if (rc) rc.textContent = rejected.length > 0 ? `(${rejected.length})` : '';

    const filtered = activeRTab === 'pending' ? pending : activeRTab === 'approved' ? approved : rejected;
    const list = document.getElementById('reviews-list');
    if (!list) return;

    if (filtered.length === 0) {
      list.innerHTML = `<div class="adm-reviews__empty">Aucun avis ${activeRTab === 'pending' ? 'en attente' : activeRTab === 'approved' ? 'approuvé' : 'refusé'}.</div>`;
      return;
    }

    list.innerHTML = filtered.map((r: any) => {
      const starStr = '★'.repeat(r.stars || 5) + '☆'.repeat(5 - (r.stars || 5));
      const date = r.date ? new Date(r.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
      let actions = '';
      if (r.status === 'pending') {
        actions = `
          <button class="adm-rv__btn adm-rv__btn--approve" data-rv-approve="${r.id}">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7.5L5.5 10L11 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Approuver
          </button>
          <button class="adm-rv__btn adm-rv__btn--reject" data-rv-reject="${r.id}">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 4l6 6M10 4l-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            Refuser
          </button>
        `;
      } else if (r.status === 'approved') {
        actions = `
          <button class="adm-rv__btn adm-rv__btn--reject" data-rv-reject="${r.id}">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 4l6 6M10 4l-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            Retirer
          </button>
        `;
      } else {
        actions = `
          <button class="adm-rv__btn adm-rv__btn--approve" data-rv-approve="${r.id}">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7.5L5.5 10L11 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Approuver
          </button>
          <button class="adm-rv__btn adm-rv__btn--delete" data-rv-delete="${r.id}">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 4h8M5.5 4V3a1 1 0 011-1h1a1 1 0 011 1v1M4.5 4v7a1.5 1.5 0 001.5 1.5h2a1.5 1.5 0 001.5-1.5V4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Supprimer
          </button>
        `;
      }

      return `
        <div class="adm-rv">
          <div class="adm-rv__stars">${starStr}</div>
          <div class="adm-rv__body">
            <p class="adm-rv__text">${escHtml(r.text)}</p>
            <div class="adm-rv__meta">
              <span class="adm-rv__name">${escHtml(r.name)}</span>
              <span class="adm-rv__sep">·</span>
              <span class="adm-rv__service">${escHtml(r.service)}</span>
              ${date ? `<span class="adm-rv__sep">·</span><span class="adm-rv__date">${date}</span>` : ''}
            </div>
          </div>
          <div class="adm-rv__actions">${actions}</div>
        </div>
      `;
    }).join('');

    // Wire up buttons
    list.querySelectorAll('[data-rv-approve]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.rvApprove!;
        if (!(await setReviewStatus(id, 'approved'))) return;
        renderAdminReviews();
        updatePendingBadge();
      });
    });
    list.querySelectorAll('[data-rv-reject]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.rvReject!;
        if (!(await setReviewStatus(id, 'rejected'))) return;
        renderAdminReviews();
        updatePendingBadge();
      });
    });
    list.querySelectorAll('[data-rv-delete]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.rvDelete!;
        const { error } = await supabase.from('reviews').delete().eq('id', id);
        if (error) { alert('Erreur, réessayez.'); return; }
        DB_REVIEWS = DB_REVIEWS.filter((x: any) => x.id !== id);
        renderAdminReviews();
        updatePendingBadge();
      });
    });
  }

  // Review tabs
  document.querySelectorAll('[data-rtab]').forEach(tab => {
    tab.addEventListener('click', () => {
      activeRTab = (tab as HTMLElement).dataset.rtab!;
      document.querySelectorAll('[data-rtab]').forEach(t => t.classList.remove('adm-reviews__tab--active'));
      tab.classList.add('adm-reviews__tab--active');
      renderAdminReviews();
    });
  });

  updatePendingBadge();
  updateRefusalBadge();
</script>

