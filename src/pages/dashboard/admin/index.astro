    transition: background 0.2s, border-color 0.2s;
  }
  .adm-g__booking-btn:hover { background: #D5ECDF; border-color: #14513A; }
  .adm-g__booking-count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 18px; height: 18px; border-radius: 9px;
    background: #14513A; color: #FAF8F4;
    font-size: 0.6rem; font-weight: 700; padding: 0 4px;
    margin-left: 2px;
  }

  /* Actions */
  .adm-g__actions { display: flex; align-items: center; gap: 8px; position: relative; }

  .adm-g__btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    padding: 8px 15px; border-radius: 10px;
    font-family: 'Jost', sans-serif; font-size: 0.72rem; font-weight: 500;
    text-decoration: none; cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    white-space: nowrap;
  }
  .adm-g__btn--outline {
    background: transparent; border: 1px solid #E7E4DB; color: #6B6B64;
  }
  .adm-g__btn--outline:hover { border-color: #14513A; color: #14513A; background: #EDF5F0; }
  .adm-g__btn--danger { color: #9C9C93; }
  .adm-g__btn--danger:hover { border-color: #DC2626; color: #DC2626; background: #FEF2F2; }

  .adm-g__flash {
    position: absolute; top: -6px; right: 0;
    background: #14513A; color: #FAF8F4; padding: 4px 12px; border-radius: 8px;
    font-size: 0.68rem; font-weight: 500; white-space: nowrap;
    animation: flashIn 0.3s ease, flashOut 0.3s ease 2s forwards;
    z-index: 5;
  }
  @keyframes flashIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes flashOut { from { opacity: 1; } to { opacity: 0; } }

  /* ============================================================
     BOOKINGS PANEL
     ============================================================ */
  .adm-g__bookings {
    grid-column: 1 / -1;
    margin-top: 12px;
    background: #F0F7F3; border: 1px solid #C8DFD1; border-radius: 14px;
    overflow: hidden;
    animation: panelIn 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes panelIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }

  .adm-g__bookings-header {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.75rem; font-weight: 600; color: #14513A;
    padding: 14px 18px; border-bottom: 1px solid #C8DFD1;
  }

  .adm-g__bk-row { border-bottom: 1px solid #D8EBE0; }
  .adm-g__bk-row:last-child { border-bottom: none; }

  .adm-g__bk-summary {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; padding: 12px 18px;
    background: transparent; border: none; cursor: pointer;
    font-family: inherit; transition: background 0.15s;
    text-align: left;
  }
  .adm-g__bk-summary:hover { background: rgba(20,81,58,0.04); }

  .adm-g__bk-summary-left {
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
  }
  .adm-g__bk-client { font-size: 0.82rem; font-weight: 600; color: #1C1C1A; }
  .adm-g__bk-dates { font-size: 0.72rem; color: #14513A; font-weight: 500; }
  .adm-g__bk-persons {
    font-size: 0.65rem; color: #9C9C93; font-weight: 500;
    background: #E8F0EC; padding: 1px 8px; border-radius: 4px;
  }
  .adm-g__bk-arrow { color: #9C9C93; transition: transform 0.25s ease; flex-shrink: 0; }

  .adm-g__bk-detail { padding: 0 18px 16px; animation: panelIn 0.2s ease; }
  .adm-g__bk-detail-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 10px 24px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.7); border-radius: 10px;
  }
  .adm-g__bk-detail-item--full { grid-column: 1 / -1; }
  .adm-g__bk-label {
    display: block; font-size: 0.6rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: #6B8F7A; margin-bottom: 1px;
  }
  .adm-g__bk-value { font-size: 0.78rem; font-weight: 500; color: #1C1C1A; }
  .adm-g__bk-value--link { color: #14513A; text-decoration: none; }
  .adm-g__bk-value--link:hover { text-decoration: underline; }

  .adm-g__bk-replacement {
    margin-top: 10px; padding: 10px 16px;
    background: rgba(185,151,82,0.08); border-radius: 10px; border: 1px solid rgba(185,151,82,0.2);
    display: flex; align-items: center; gap: 6px;
    font-size: 0.72rem; color: #B99752; font-weight: 500;
  }
  .adm-g__bk-replacement strong { color: #1C1C1A; }

  .adm-g__bk-status {
    font-size: 0.62rem; font-weight: 600; padding: 2px 8px; border-radius: 20px;
  }
  .adm-g__bk-status--refused { background: rgba(230,126,34,0.12); color: #E67E22; }
  .adm-g__bk-status--seen { background: #E8F5EE; color: #16A34A; }
  .adm-g__bk-status--unseen { background: #F5F4F0; color: #9C9C93; }
  .adm-g__bk-status--replaced { background: rgba(185,151,82,0.12); color: #B99752; }
  .adm-g__bk-status--activity { background: #EDF5F0; color: #14513A; }

  /* ============================================================
     REFUSAL PANEL
     ============================================================ */
  .adm-g__refusal {
    grid-column: 1 / -1;
    margin-top: 12px; padding: 20px;
    background: #FEF2F2; border: 1px solid #FECACA; border-radius: 14px;
  }
  .adm-g__refusal-header {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.78rem; font-weight: 600; color: #DC2626; margin-bottom: 10px;
  }
  .adm-g__refusal-msg {
    margin: 0 0 12px; padding: 0 0 0 16px;
    border-left: 3px solid #FECACA;
    font-size: 0.82rem; color: #7F1D1D; line-height: 1.6; font-style: italic;
  }
  .adm-g__refusal-date { font-size: 0.75rem; color: #9C9C93; margin: 0 0 8px; }
  .adm-g__refusal-date strong { color: #1C1C1A; }
  .adm-g__refusal-client { font-size: 0.75rem; color: #9C9C93; margin: 0 0 16px; }
  .adm-g__refusal-client strong { color: #1C1C1A; }
  .adm-g__no-replace { font-size: 0.78rem; color: #9C9C93; font-style: italic; margin: 8px 0 0; }

  .adm-g__ref-row { border-bottom: 1px solid #F5CDCD; }
  .adm-g__ref-row:last-child { border-bottom: none; }

  .adm-g__ref-summary {
    display: flex; align-items: center; gap: 10px;
    width: 100%; padding: 14px 18px;
    background: transparent; border: none; cursor: pointer;
    font-family: inherit; text-align: left;
    transition: background 0.12s;
  }
  .adm-g__ref-summary:hover { background: rgba(220,38,38,0.04); }
  .adm-g__ref-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #EF4444; flex-shrink: 0;
  }
  .adm-g__ref-summary-left {
    flex: 1; display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
  }
  .adm-g__ref-date { font-size: 0.82rem; font-weight: 600; color: #1C1C1A; }
  .adm-g__ref-client { font-size: 0.72rem; color: #9C9C93; }
  .adm-g__ref-arrow { color: #9C9C93; transition: transform 0.25s ease; flex-shrink: 0; }

  .adm-g__ref-detail { padding: 0 18px 18px; animation: panelIn 0.2s ease; }
  .adm-g__ref-reason { margin-bottom: 16px; }
  .adm-g__ref-reason-label {
    display: block; font-size: 0.68rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: #9C9C93; margin-bottom: 6px;
  }

  .adm-g__refusal-actions {
    margin-top: 20px; padding-top: 16px;
    border-top: 1px solid #FECACA;
    display: flex; justify-content: flex-end;
  }
  .adm-g__refusal-confirm {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 28px;
    background: linear-gradient(135deg, #14513A, #0C3A28);
    color: #FAF8F4;
    border: none; border-radius: 12px;
    font-size: 0.82rem; font-weight: 600;
    cursor: pointer; font-family: 'Jost', sans-serif;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .adm-g__refusal-confirm:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(20,81,58,0.25);
  }

  .adm-g__rcard-radio {
    width: 18px; height: 18px; accent-color: #14513A; cursor: pointer; flex-shrink: 0;
  }
  .adm-g__rcard-radio:disabled { cursor: not-allowed; opacity: 0.3; }

  .adm-g__rcard--unavailable { opacity: 0.55; }
  .adm-g__rcard--unavailable .adm-g__rcard-header { cursor: default; }

  .adm-g__rcard-avail {
    display: inline-block; font-size: 0.6rem; font-weight: 600;
    color: #14513A; background: #E6F2EC; padding: 1px 8px; border-radius: 20px;
    margin-left: 4px;
  }
  .adm-g__rcard-unavail {
    display: inline-block; font-size: 0.6rem; font-weight: 600;
    color: #DC2626; background: #FEF2F2; padding: 1px 8px; border-radius: 20px;
    margin-left: 4px;
  }

  .adm-g__replace-label {
    font-size: 0.72rem; font-weight: 600; color: #6B6B64;
    margin: 0 0 10px; text-transform: uppercase; letter-spacing: 0.06em;
  }
  .adm-g__replace-list { display: flex; flex-direction: column; gap: 8px; }

  .adm-g__replace-av {
    width: 34px; height: 34px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.6rem; font-weight: 700; color: rgba(255,255,255,0.55);
    flex-shrink: 0;
  }
  .adm-g__replace-av--medina { background: linear-gradient(135deg, #14513A, #0C3A28); }
  .adm-g__replace-av--mecca { background: linear-gradient(135deg, #1A1A2E, #2D2D4A); }
  .adm-g__replace-av--photo { background-size: cover; background-position: center; color: transparent; }

  .adm-g__replace-name { display: block; font-size: 0.78rem; font-weight: 600; color: #1C1C1A; }
  .adm-g__replace-info { display: block; font-size: 0.65rem; color: #9C9C93; }

  /* Replacement cards */
  .adm-g__rcard {
    border: 1px solid #E7E4DB; border-radius: 12px; background: #FFF;
    overflow: hidden; transition: border-color 0.2s, box-shadow 0.2s;
  }
  .adm-g__rcard:hover { border-color: rgba(20,81,58,0.25); box-shadow: 0 6px 18px rgba(20,81,58,0.06); }
  .adm-g__rcard-header {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 14px; cursor: pointer; user-select: none;
  }
  .adm-g__rcard-info { flex: 1; min-width: 0; }
  .adm-g__rcard-arrow { color: #9C9C93; transition: transform 0.25s ease; flex-shrink: 0; }
  .adm-g__rcard-body { padding: 0 14px 14px; }
  .adm-g__rcard-profile {
    padding: 10px 0; border-top: 1px solid #F0EDE6;
    font-size: 0.75rem; color: #6B6B64;
  }
  .adm-g__rcard-detail { display: flex; flex-wrap: wrap; gap: 4px 16px; margin-bottom: 8px; }
  .adm-g__rcard-detail span { white-space: nowrap; }
  .adm-g__rcard-detail strong { color: #1C1C1A; font-weight: 600; }
  .adm-g__rcard-label {
    font-size: 0.62rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.06em; color: #9C9C93; margin-right: 6px;
  }
  .adm-g__rcard-value { font-size: 0.75rem; color: #1C1C1A; }
  .adm-g__rcard-profile-link {
    display: inline-flex; align-items: center; gap: 5px;
    margin-top: 6px; font-size: 0.7rem;
    color: #14513A; text-decoration: underline; text-underline-offset: 2px;
  }
  .adm-g__rcard-profile-link:hover { color: #1E6B4E; }

  /* Mini calendar */
  .adm-cal {
    margin: 8px 0 12px; padding: 14px;
    background: #FAF9F5;
    border: 1px solid #ECE9E1; border-radius: 12px;
  }
  .adm-cal__header {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 6px;
    margin-bottom: 8px;
  }
  .adm-cal__title { font-size: 0.78rem; font-weight: 600; color: #1C1C1A; }
  .adm-cal__legend { display: flex; gap: 10px; font-size: 0.6rem; color: #9C9C93; flex-wrap: wrap; }
  .adm-cal__legend-item { display: flex; align-items: center; gap: 4px; }
  .adm-cal__dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; }
  .adm-cal__dot--avail { background: #14513A; }
  .adm-cal__dot--busy { background: #D64545; }
  .adm-cal__dot--booked { background: #C0392B; }

  .adm-cal__grid {
    display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px;
    text-align: center;
  }
  .adm-cal__day-label {
    font-size: 0.58rem; font-weight: 600; color: #9C9C93;
    padding: 4px 0; text-transform: uppercase;
  }
  .adm-cal__empty { padding: 4px 0; }
  .adm-cal__day {
    font-size: 0.68rem; padding: 5px 0; border-radius: 6px;
    font-weight: 500;
  }
  .adm-cal__day--avail { background: #E6F2EC; color: #14513A; }
  .adm-cal__day--busy { background: #FDE8E8; color: #D64545; }
  .adm-cal__day--booked { background: #C0392B; color: #FFF; font-weight: 700; }
  .adm-cal__day--past { background: transparent; color: #D5D5CE; }

  .adm-cal__nav {
    display: flex; align-items: center; justify-content: center;
    gap: 16px; margin-top: 8px;
  }
  .adm-cal__nav-btn {
    display: flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 50%;
    border: 1px solid #E7E4DB; background: #FFF;
    cursor: pointer; color: #6B6B64;
    transition: border-color 0.2s, color 0.2s;
  }
  .adm-cal__nav-btn:hover { border-color: #14513A; color: #14513A; }

  .adm-g__rcard-select {
    display: block; width: 100%; padding: 10px;
    background: #14513A; color: #FAF8F4; border: none; border-radius: 10px;
    font-size: 0.78rem; font-weight: 600; cursor: pointer;
    font-family: inherit; transition: background 0.2s;
  }
  .adm-g__rcard-select:hover { background: #1E6B4E; }

  /* ============================================================
     CREDENTIALS PANEL
     ============================================================ */
  .adm-g__creds {
    grid-column: 1 / -1;
    margin-top: 12px; padding: 20px;
    background: #FAF9F5; border: 1px solid #ECE9E1; border-radius: 14px;
    animation: panelIn 0.25s ease;
  }
  .adm-g__creds h4 {
    font-size: 0.82rem; font-weight: 600; margin: 0 0 14px; color: #1C1C1A;
  }
  .adm-g__creds-form { display: flex; align-items: flex-end; gap: 12px; flex-wrap: wrap; }
  .adm-g__creds-field { flex: 1; min-width: 160px; }
  .adm-g__creds-field label {
    display: block; font-size: 0.65rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: #9C9C93; margin-bottom: 4px;
  }
  .adm-g__creds-field input {
    width: 100%; padding: 10px 14px;
    border: 1px solid #E7E4DB; border-radius: 10px;
    font-size: 0.82rem; font-family: inherit; background: #FFF;
    transition: border-color 0.2s;
  }
  .adm-g__creds-field input:focus { outline: none; border-color: #14513A; }
  .adm-g__creds-save {
    padding: 10px 20px; background: #14513A; color: #FAF8F4;
    border: none; border-radius: 10px; font-size: 0.75rem; font-weight: 600;
    cursor: pointer; font-family: inherit; transition: background 0.2s;
  }
  .adm-g__creds-save:hover { background: #1E6B4E; }
  .adm-g__creds-note {
    font-size: 0.72rem; color: #9C9C93; line-height: 1.6;
    margin: 0; align-self: center;
  }

  /* ============================================================
     MODAL
     ============================================================ */
  .adm-modal-overlay {
    position: fixed; inset: 0;
    background: rgba(8,40,24,0.5); backdrop-filter: blur(5px);
    z-index: 200;
    display: flex; align-items: center; justify-content: center;
    padding: 20px;
  }
  .adm-modal {
    background: #FFF; border-radius: 20px;
    width: 100%; max-width: 520px;
    box-shadow: 0 40px 90px rgba(0,0,0,0.3);
    animation: modalIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    max-height: 90vh; max-height: 90dvh;
    overflow-y: auto;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: translateY(16px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .adm-modal__header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 22px 26px; border-bottom: 1px solid #F3F0EA;
    position: sticky; top: 0; background: #FFF; z-index: 2;
    border-radius: 20px 20px 0 0;
  }
  .adm-modal__header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.35rem; font-weight: 700; margin: 0; color: #14513A;
  }
  .adm-modal__close {
    width: 34px; height: 34px; border-radius: 10px; border: none;
    background: #F3F0EA; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: #6B6B64; transition: background 0.15s, color 0.15s;
  }
  .adm-modal__close:hover { background: #FEE2E2; color: #DC2626; }

  .adm-modal__body { padding: 26px; }

  /* Photo upload */
  .adm-form-photo {
    display: flex; flex-direction: column; align-items: center;
    margin-bottom: 24px; gap: 12px;
  }
  .adm-form-photo__input { display: none; }
  .adm-form-photo__btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 18px; border: 1px solid #E7E4DB; border-radius: 20px;
    background: #FFF; color: #6B6B64; font-size: 0.72rem; font-weight: 500;
    cursor: pointer; font-family: inherit;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .adm-form-photo__btn:hover { border-color: #14513A; color: #14513A; background: #EDF5F0; }

  .adm-form-photo__empty { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .adm-form-photo__placeholder {
    width: 104px; height: 104px; border-radius: 50%;
    background: #F6F4EE; border: 2px dashed #D5D0C7;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 4px; color: #9C9C93; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .adm-form-photo__placeholder:hover { border-color: #14513A; background: #EDF5F0; }
  .adm-form-photo__placeholder span { font-size: 0.58rem; text-align: center; line-height: 1.2; }

  .adm-form-photo__editor {
    display: flex; flex-direction: column; align-items: center; gap: 12px;
    animation: panelIn 0.2s ease;
  }
  .adm-form-photo__editor-hint { font-size: 0.7rem; color: #9C9C93; margin: 0; font-weight: 500; }
  .adm-form-photo__crop {
    width: 160px; height: 160px; border-radius: 50%;
    overflow: hidden; position: relative; cursor: grab;
    border: 3px solid #14513A;
    box-shadow: 0 0 0 4px rgba(20,81,58,0.1), 0 4px 20px rgba(0,0,0,0.1);
    background: #1C1C1A;
  }
  .adm-form-photo__crop img {
    position: absolute; top: 0; left: 0;
    width: auto; height: auto;
    max-width: none; max-height: none;
    transform-origin: 0 0;
    pointer-events: none; user-select: none;
    -webkit-user-drag: none;
    display: block;
  }
  .adm-form-photo__zoom {
    display: flex; align-items: center; gap: 8px; color: #9C9C93;
    width: 180px;
  }
  .adm-form-photo__zoom input[type="range"] {
    flex: 1; height: 4px; -webkit-appearance: none; appearance: none;
    background: #E7E4DB; border-radius: 2px; outline: none;
  }
  .adm-form-photo__zoom input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none; width: 15px; height: 15px;
    border-radius: 50%; background: #14513A; cursor: pointer;
    border: 2px solid #FFF; box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }
  .adm-form-photo__zoom input[type="range"]::-moz-range-thumb {
    width: 15px; height: 15px; border-radius: 50%; background: #14513A;
    cursor: pointer; border: 2px solid #FFF; box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }
  .adm-form-photo__editor-actions { display: flex; gap: 8px; }
  .adm-form-photo__editor-cancel {
    padding: 8px 18px; background: #F3F0EA; border: none; border-radius: 20px;
    font-size: 0.72rem; font-weight: 600; cursor: pointer; font-family: inherit;
    color: #6B6B64; transition: background 0.15s;
  }
  .adm-form-photo__editor-cancel:hover { background: #E8E5DE; }
  .adm-form-photo__editor-confirm {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 8px 20px; background: #14513A; color: #FAF8F4;
    border: none; border-radius: 20px;
    font-size: 0.72rem; font-weight: 600; cursor: pointer; font-family: inherit;
    transition: background 0.15s;
  }
  .adm-form-photo__editor-confirm:hover { background: #0C3A28; }

  .adm-form-photo__result { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .adm-form-photo__result-circle {
    width: 104px; height: 104px; border-radius: 50%;
    background-size: cover; background-position: center;
    border: 3px solid #14513A;
