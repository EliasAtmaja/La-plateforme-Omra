---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { getLangFromUrl, t, getLocalePath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout title={t(lang, 'about.title')} description="Découvrez La plateforme Omra, la première plateforme de mise en relation entre pèlerins et guides locaux qualifiés.">

  <section class="about-hero">
    <div class="container">
      <p class="section__subtitle load-rise" style="--load-delay: 100ms">{t(lang, 'about.subtitle')}</p>
      <h1 class="about-hero__title load-rise" style="--load-delay: 250ms">{t(lang, 'about.title')}</h1>
    </div>
  </section>

  <section class="about-content section">
    <div class="container container--narrow">

      <div class="about-block reveal">
        <h2>Notre Mission</h2>
        <p>Optimiser et sublimer votre exp&eacute;rience sur place. La Plateforme Omra est le premier espace digital francophone qui connecte directement les invit&eacute;s d'Allah avec des professionnels locaux certifi&eacute;s pour des prestations sur mesure. Nous ne vendons pas de voyages&nbsp;: nous mettons notre expertise &agrave; votre service pour vous guider physiquement et spirituellement une fois arriv&eacute; &agrave; destination.</p>
      </div>

      <div class="about-block reveal">
        <h2>Plus de 10 ans de terrain au service de votre s&eacute;r&eacute;nit&eacute;</h2>
        <p>La Plateforme Omra, c'est avant tout le fruit de plus de 10 ann&eacute;es d'expertise et de pr&eacute;sence continue en Arabie Saoudite. Forts de cette immersion totale et ayant d&eacute;j&agrave; accompagn&eacute; plus de 10&nbsp;000 p&egrave;lerins dans leur cheminement, nous connaissons le terrain dans ses moindres d&eacute;tails.</p>
        <p>Aujourd'hui, nous mettons ce savoir-faire unique &agrave; votre disposition en vous connectant directement avec la fine fleur des professionnels locaux. En &eacute;liminant les interm&eacute;diaires et le hasard, nous vous permettons de r&eacute;server vos accompagnateurs en totale tranquillit&eacute; d'esprit. Vous pouvez &ecirc;tre pleinement serein&nbsp;: vous &ecirc;tes entre de bonnes mains.</p>
      </div>

      <div class="about-block reveal">
        <h2>Un accompagnement continu, &agrave; port&eacute;e de main</h2>
        <p>Parce qu'un voyage sacr&eacute; ne s'arr&ecirc;te pas &agrave; une r&eacute;servation, nous sommes &agrave; vos c&ocirc;t&eacute;s &agrave; chaque instant. Via notre WhatsApp, vous aurez toujours quelqu'un pour vous r&eacute;pondre, vous orienter et r&eacute;pondre pr&eacute;cis&eacute;ment &agrave; vos besoins tout au long de votre s&eacute;jour. O&ugrave; que vous soyez, un interlocuteur bienveillant reste disponible pour vous apporter &eacute;coute et assistance.</p>
      </div>

      <div class="about-block reveal">
        <h2>Quatre piliers d'accompagnement sur place</h2>
        <p>Pour vous garantir un s&eacute;jour fluide et enrichissant, nos professionnels interviennent exclusivement sur vos besoins r&eacute;els&nbsp;:</p>
        <div class="about-pillars stagger">
          <div class="about-pillar reveal">
            <div class="about-pillar__icon" aria-hidden="true">
              <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="18" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 42c0-7.7 6.3-14 14-14s14 6.3 14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>L'accompagnement pour la Omra</h3>
            <p>Un guide &agrave; vos c&ocirc;t&eacute;s pour accomplir vos rites pas &agrave; pas, en stricte conformit&eacute; avec la Sounnah et le suivi du proph&egrave;te Sallallahu Alayhi wa Sallam.</p>
          </div>
          <div class="about-pillar reveal">
            <div class="about-pillar__icon" aria-hidden="true">
              <svg viewBox="0 0 48 48" fill="none"><path d="M24 6l16 8v12c0 10-6.5 19-16 24C14.5 45 8 36 8 26V14l16-8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M18 24l4 4 8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Les visites historiques &agrave; La Mecque</h3>
            <p>Une immersion culturelle pour comprendre l'histoire des lieux sacr&eacute;s et en tirer des le&ccedil;ons spirituelles profondes.</p>
          </div>
          <div class="about-pillar reveal">
            <div class="about-pillar__icon" aria-hidden="true">
              <svg viewBox="0 0 48 48" fill="none"><path d="M24 4v8M4 24h8M36 24h8M24 36v8M11 11l5.6 5.6M31.4 31.4L37 37M11 37l5.6-5.6M31.4 16.6L37 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="24" cy="24" r="6" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <h3>Les visites historiques &agrave; M&eacute;dine</h3>
            <p>Des explications riches et sourc&eacute;es lors de vos visites dans la ville du Messager Sallallahu Alayhi wa Sallam.</p>
          </div>
          <div class="about-pillar reveal">
            <div class="about-pillar__icon" aria-hidden="true">
              <svg viewBox="0 0 48 48" fill="none"><rect x="6" y="12" width="36" height="26" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M6 20h36" stroke="currentColor" stroke-width="1.5"/><path d="M14 28h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M14 32h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <h3>Les sorties shopping optimis&eacute;es</h3>
            <p>Un accompagnement local pour effectuer vos achats efficacement, &eacute;viter les pi&egrave;ges et ne pas perdre un temps pr&eacute;cieux destin&eacute; &agrave; l'adoration.</p>
          </div>
        </div>
      </div>

      <div class="about-block reveal">
        <h2>Une confiance absolue et v&eacute;rifi&eacute;e</h2>
        <p>Sur notre plateforme, la s&eacute;r&eacute;nit&eacute; est notre fondation. Forts de notre exp&eacute;rience d&eacute;cennale, nous appliquons un processus de s&eacute;lection drastique. Chaque professionnel local est rigoureusement v&eacute;rifi&eacute;&nbsp;: des comp&eacute;tences valid&eacute;es, une ma&icirc;trise parfaite de la logistique du terrain, et une connaissance approfondie des rites. Vous avancez l'esprit tranquille, le c&oelig;ur apais&eacute; et le bagage spirituel enrichi.</p>
      </div>

      <div class="about-block about-block--closing reveal">
        <p>Parce que votre temps dans les Lieux Saints est pr&eacute;cieux et sacr&eacute;, La Plateforme Omra met 10 ans d'expertise, une assistance d&eacute;di&eacute;e et les meilleurs profils locaux &agrave; votre service. Vivez votre s&eacute;jour avec intensit&eacute;, science et une tranquillit&eacute; d'esprit absolue.</p>
      </div>

      <div class="about-cta">
        <Button variant="primary" size="lg" href={getLocalePath(lang, '/guides/')}>
          {t(lang, 'hero.cta')}
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    background: linear-gradient(180deg, var(--color-primary-50) 0%, var(--color-background) 100%);
    padding: var(--space-20) 0 var(--space-12);
    text-align: center;
  }

  .about-hero__title {
    font-size: var(--text-5xl);
    color: var(--color-secondary);
  }

  .about-block {
    margin-bottom: var(--space-16);
  }

  .about-block h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
    color: var(--color-secondary);
  }

  .about-block p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .about-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    margin-top: var(--space-6);
  }

  .about-pillar {
    padding: var(--space-6);
    background: var(--color-primary-50, #F0F7F4);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .about-pillar:hover {
    border-color: var(--color-primary-200);
    box-shadow: 0 16px 40px rgba(20,81,58,0.08);
  }

  .about-pillar__icon {
    width: 40px;
    height: 40px;
    margin-bottom: var(--space-3);
    color: var(--color-accent-dark);
  }
  .about-pillar__icon svg { width: 100%; height: 100%; }

  .about-pillar h3 {
    font-size: var(--text-base);
    margin-bottom: var(--space-2);
    color: var(--color-secondary);
  }

  .about-pillar p {
    font-size: var(--text-sm);
    margin-bottom: 0;
    line-height: 1.7;
  }

  .about-block--closing {
    padding: var(--space-8);
    background: linear-gradient(135deg, #FAF8F4 0%, #F0EDE5 100%);
    border-radius: var(--radius-xl);
    text-align: center;
  }
  .about-block--closing p {
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-secondary);
    margin-bottom: 0;
  }

  .about-cta {
    text-align: center;
    padding-top: var(--space-8);
  }

  @media (max-width: 639px) {
    .about-hero__title { font-size: var(--text-3xl); }
    .about-pillars { grid-template-columns: 1fr; }
  }
</style>
