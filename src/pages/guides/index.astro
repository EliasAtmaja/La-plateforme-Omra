---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, t, getLocalePath } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout title={t(lang, 'nav.guides')} description={t(lang, 'guides.subtitle')}>

  <div class="gp-hero">
    <div class="gp-container">
      <h1 class="gp-hero__title reveal">Nos guides</h1>
      <p class="gp-hero__sub reveal">Choisissez votre guide certifi&eacute; et r&eacute;servez en quelques clics</p>
    </div>
  </div>

  <!-- Filtres -->
  <section class="gp-filters">
    <div class="gp-container">
      <div class="gp-filters__row">
        <span class="gp-filter__text">Je recherche un guide</span>
        <div class="gp-filter__select-wrap" id="filter-gender">
          <select class="gp-filter__select" id="filter-gender-select">
            <option value="">Tous</option>
            <option value="homme">Homme</option>
            <option value="femme">Femme</option>
          </select>
          <svg class="gp-filter__select-icon" width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M4 7l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </div>
    </div>
  </section>

  <section class="gp-list">
    <div class="gp-container stagger" id="guides-list">
      <p class="gp-empty" id="guides-empty" hidden>Aucun guide disponible pour le moment.</p>
    </div>
  </section>

</BaseLayout>

<script>
  import { supabase, mapGuide, mapReview, ALL_SLOTS } from '../../lib/supabase';

  const MONTH_NAMES = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
  const calStates: Record<string, { year: number; month: number; selectedDate: string | null; selectedSlot: string | null }> = {};

  let filterGender: string = '';

  function initFilters() {
    const sel = document.getElementById('filter-gender-select') as HTMLSelectElement | null;
    if (!sel) return;
    sel.addEventListener('change', () => {
      filterGender = sel.value;
      renderGuidesList();
    });
  }
  initFilters();

  function esc(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  // ---- Données Supabase (chargées une fois, servies depuis un cache mémoire) ----
  let GUIDES: any[] = [];
  let REVIEWS: any[] = []; // avis approuvés uniquement (filtrés par RLS)
  // guideId -> date -> créneaux disponibles / créneaux réservés
  let AVAIL: Record<string, Record<string, string[]>> = {};
  let BOOKED: Record<string, Record<string, string[]>> = {};

  function getGuides(): any[] { return GUIDES; }
  function getApprovedReviews(guideId: string): any[] {
    return REVIEWS.filter((r: any) => r.guideId === guideId);
  }

  // Créneaux encore réservables pour un guide à une date donnée
  function freeSlotsFor(guideId: string, dateStr: string): string[] {
    const av = (AVAIL[guideId] || {})[dateStr];
    if (!av || av.length === 0) return [];
    const bk = (BOOKED[guideId] || {})[dateStr] || [];
    if (bk.includes('*')) return []; // ancienne réservation « journée entière »
    return av.filter((s: string) => !bk.includes(s));
  }

  async function loadData() {
    const [gRes, rRes, aRes, bRes] = await Promise.all([
      supabase.from('guides').select('*').order('created_at'),
      supabase.from('reviews').select('*').not('guide_id', 'is', null),
      supabase.from('availability').select('guide_id, date, slots'),
      supabase.from('booked_dates').select('guide_id, date, slot'),
    ]);
    GUIDES = (gRes.data || []).map(mapGuide);
    REVIEWS = (rRes.data || []).map(mapReview);
    AVAIL = {};
    (aRes.data || []).forEach((r: any) => {
      (AVAIL[r.guide_id] = AVAIL[r.guide_id] || {})[r.date] = r.slots || ALL_SLOTS.slice();
    });
    BOOKED = {};
    (bRes.data || []).forEach((r: any) => {
      const m = (BOOKED[r.guide_id] = BOOKED[r.guide_id] || {});
      (m[r.date] = m[r.date] || []).push(r.slot || '*');
    });
  }

  const LANG_CODES: Record<string, string> = {
    'français': 'FR', 'francais': 'FR', 'arabe': 'AR', 'anglais': 'EN',
    'espagnol': 'ES', 'turc': 'TR', 'ourdou': 'UR', 'indonésien': 'ID', 'indonesien': 'ID',
  };
  function langCode(l: string): string {
    return LANG_CODES[l.trim().toLowerCase()] || l.trim().slice(0, 2).toUpperCase();
  }

  function starsRowHtml(avg: number): string {
    const full = Math.round(avg);
    let out = '';
    for (let i = 1; i <= 5; i++) {
      out += `<span class="gp-star ${i <= full ? 'gp-star--full' : ''}">★</span>`;
    }
    return out;
  }

  function renderGuidesList() {
    const list = document.getElementById('guides-list');
    const empty = document.getElementById('guides-empty');
    if (!list) return;

    let guides = getGuides();
    if (filterGender) guides = guides.filter((g: any) => g.gender === filterGender);
    const existing = list.querySelectorAll('.gp-card');
    existing.forEach(el => el.remove());
    document.querySelectorAll('body > .gp-cal').forEach(el => el.remove());

    if (guides.length === 0) {
      if (empty) {
        empty.textContent = filterGender
          ? 'Aucun guide ne correspond à vos critères.'
          : 'Aucun guide disponible pour le moment.';
        empty.hidden = false;
      }
      return;
    }
    if (empty) empty.hidden = true;

    guides.forEach((g: any) => {
      const cityLabel = g.city === 'medina' ? 'Médine' : 'La Mecque';
      const initials = (g.firstName?.[0] || '') + (g.lastName?.[0] || '');
      const langCodes: string[] = (g.languages || []).map((l: string) => langCode(l));
      const langPills = langCodes.map((c: string) => `<span class="gp-card__lang">${esc(c)}</span>`).join('');
      const langsFull = (g.languages || []).map((l: string) => `<span class="gp-profile__lang">${esc(l.trim())}</span>`).join('');

      const guideReviews = getApprovedReviews(g.id);
      const reviewCount = guideReviews.length;
      const avgRating = reviewCount > 0
        ? guideReviews.reduce((s: number, r: any) => s + (r.stars || 5), 0) / reviewCount
        : 0;
      const avgLabel = avgRating.toFixed(1).replace('.', ',');

      const ratingHtml = reviewCount > 0
        ? `<div class="gp-card__rating"><span class="gp-card__rating-star">★</span><span class="gp-card__rating-num">${avgLabel}</span><span class="gp-card__reviews">(${reviewCount} avis)</span></div>`
        : `<div class="gp-card__rating"><span class="gp-card__rating-star">★</span><span class="gp-card__reviews">(0 avis)</span></div>`;

      const avatarHtml = g.photo
        ? `<div class="gp-card__avatar gp-card__avatar--photo" style="background-image:url(${g.photo})"></div>`
        : `<div class="gp-card__avatar gp-card__avatar--${g.city}">${esc(initials)}</div>`;

      const visualImg = g.photo
        ? `<img src="${g.photo}" alt="${esc(g.firstName)} ${esc(g.lastName)}" class="guide-visual__image" />`
        : `<div class="guide-visual__image guide-visual__image--initials guide-visual__image--${g.city}">${esc(initials)}</div>`;

      const textReviews = guideReviews.filter((r: any) => (r.text || '').trim().length > 0);
      const randomReview = textReviews.length > 0 ? textReviews[Math.floor(Math.random() * textReviews.length)] : null;

      const reviewsBlockHtml = reviewCount > 0
        ? `
          <div class="gp-profile__reviews">
            <div class="gp-profile__rv-avg">
              <span class="gp-profile__rv-label">Moyenne des avis</span>
              <span class="gp-profile__rv-score">${avgLabel}<em>/5</em></span>
              <span class="gp-profile__rv-stars">${starsRowHtml(avgRating)}</span>
              <span class="gp-profile__rv-count">Bas&eacute; sur ${reviewCount} avis</span>
            </div>
            <div class="gp-profile__rv-quote">
              <span class="gp-profile__rv-label">Ils ont voyag&eacute; avec ${esc(g.firstName)}</span>
              ${randomReview
                ? `<p class="gp-profile__rv-text">&ldquo;${esc(randomReview.text)}&rdquo;</p><span class="gp-profile__rv-author">&ndash; ${esc(randomReview.name || 'Anonyme')}</span>`
                : `<p class="gp-profile__rv-text gp-profile__rv-text--empty">Aucun commentaire d&eacute;taill&eacute; pour le moment.</p>`}
              <button type="button" class="gp-profile__rv-all" data-all-reviews="${g.id}">
                Voir tous les avis
                <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>`
        : `
          <div class="gp-profile__reviews gp-profile__reviews--empty">
            <span class="gp-profile__rv-label">Avis</span>
            <p class="gp-profile__rv-text gp-profile__rv-text--empty">Aucun avis pour le moment. Soyez le premier &agrave; voyager avec ${esc(g.firstName)} !</p>
          </div>`;

      const card = document.createElement('article');
      card.className = 'gp-card reveal is-visible';
      card.dataset.guideId = g.id;
      card.innerHTML = `
        <div class="gp-card__body">
          <div class="gp-card__main">
            ${avatarHtml}
            <div class="gp-card__info">
              <h2 class="gp-card__name">${esc(g.firstName)} ${esc(g.lastName)}</h2>
              ${g.diploma ? `<p class="gp-card__diploma">${esc(g.diploma)}</p>` : ''}
              ${langCodes.length ? `<div class="gp-card__langs">${langPills}</div>` : ''}
              ${ratingHtml}
            </div>
            <div class="gp-card__right">
              ${g.pricePerDay ? `<div class="gp-card__price"><span class="gp-card__amount">${esc(String(g.pricePerDay))}&euro;</span><span class="gp-card__unit">Frais inclus</span></div>` : ''}
              <button class="gp-card__avail-btn" type="button" data-open-cal="${g.id}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="4" y="5.5" width="16" height="15" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M4 10h16M8.5 3.5v3.5M15.5 3.5v3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                Les disponibilit&eacute;s
              </button>
            </div>
          </div>

          <button class="gp-card__toggle" type="button" data-toggle-profile="${g.id}" aria-expanded="false">
            Voir le profil
            <svg class="gp-card__toggle-icon" width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4 7l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>

          <div class="gp-profile" id="profile-${g.id}">
            <div class="gp-profile__inner">
              <div class="gp-profile__sheet">
                <div class="gp-profile__top">
                  <div class="guide-visual">
                    ${visualImg}
                  </div>
                  <div class="gp-profile__id">
                    <span class="gp-profile__city">
                      <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M10 18s6-5.2 6-9.5A6 6 0 0 0 4 8.5C4 12.8 10 18 10 18z" stroke="currentColor" stroke-width="1.6"/><circle cx="10" cy="8.5" r="2" stroke="currentColor" stroke-width="1.6"/></svg>
                      ${esc(cityLabel.toUpperCase())}
                    </span>
                    <h3 class="gp-profile__name">${esc(g.firstName)} ${esc(g.lastName)}</h3>
                    ${g.diploma ? `<p class="gp-profile__diploma">${esc(g.diploma)}</p>` : ''}
                    ${langsFull ? `<div class="gp-profile__langs">${langsFull}</div>` : ''}
                    ${g.description ? `<p class="gp-profile__desc">${esc(g.description)}</p>` : ''}
                  </div>
                </div>

                ${reviewsBlockHtml}
              </div>
            </div>
          </div>

          <div class="gp-cal is-hidden" id="cal-${g.id}">
          <div class="gp-cal__panel">
          <button type="button" class="gp-cal__close" data-cal-close="${g.id}" aria-label="Fermer">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </button>
          <div class="gp-cal__header">
            <h3 class="gp-cal__title">Choisissez quand effectuer votre Omra</h3>
            <p class="gp-cal__guide-name">avec ${esc(g.firstName)} ${esc(g.lastName)}</p>
          </div>
          <div class="gp-cal__calwrap" id="cal-wrap-${g.id}">
            <div class="gp-cal__calwrap-inner">
            <div class="gp-cal__nav">
              <button type="button" class="gp-cal__arrow" data-cal-prev="${g.id}" aria-label="Mois pr&eacute;c&eacute;dent">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11 4L6 9L11 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <span class="gp-cal__month" id="cal-month-${g.id}"></span>
              <button type="button" class="gp-cal__arrow" data-cal-next="${g.id}" aria-label="Mois suivant">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M7 4L12 9L7 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
            <div class="gp-cal__weekdays">
              <span>Lun</span><span>Mar</span><span>Mer</span><span>Jeu</span><span>Ven</span><span>Sam</span><span>Dim</span>
            </div>
            <div class="gp-cal__grid" id="cal-grid-${g.id}"></div>
            <div class="gp-cal__legend">
              <span class="gp-cal__legend-item"><span class="gp-cal__dot gp-cal__dot--available"></span> Disponible</span>
              <span class="gp-cal__legend-item"><span class="gp-cal__dot gp-cal__dot--unavailable"></span> Indisponible</span>
            </div>
            </div>
          </div>
          <button type="button" class="gp-cal__reopen is-hidden" id="cal-reopen-${g.id}" data-cal-reopen="${g.id}">
            <svg class="gp-cal__reopen-icon" width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 7l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Rouvrir le calendrier
          </button>
          <div class="gp-cal__selection is-hidden" id="cal-sel-${g.id}">
            <p class="gp-cal__selected-date" id="cal-date-${g.id}"></p>
            <div class="gp-cal__slots">
              <p class="gp-cal__slots-label">Choisissez un cr&eacute;neau :</p>
              <div class="gp-cal__slots-grid">
                <button type="button" class="gp-cal__slot" data-slot="Matin" data-guide-id="${g.id}">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="14" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M12 6.5V4.5M5.5 14h-2M20.5 14h-2M7.4 9.4L6 8M16.6 9.4L18 8M3 18.5h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  Matin
                </button>
                <button type="button" class="gp-cal__slot" data-slot="Après-midi" data-guide-id="${g.id}">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.5"/><path d="M12 3.5v2M12 18.5v2M3.5 12h2M18.5 12h2M6 6l1.4 1.4M18 6l-1.4 1.4M6 18l1.4-1.4M18 18l-1.4-1.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  Apr&egrave;s-midi
                </button>
                <button type="button" class="gp-cal__slot" data-slot="Soir" data-guide-id="${g.id}">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="16" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M3 20.5h18M5.5 16h-2M20.5 16h-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  Soir
                </button>
                <button type="button" class="gp-cal__slot" data-slot="Nuit" data-guide-id="${g.id}">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M19 14.5A7.5 7.5 0 0 1 9.5 5 7.5 7.5 0 1 0 19 14.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                  Nuit
                </button>
              </div>
            </div>
            <div class="gp-cal__actions">
              <button type="button" class="gp-cal__action gp-cal__action--secondary" data-action="browse" data-guide-id="${g.id}" disabled>R&eacute;server et continuer de surfer</button>
              <button type="button" class="gp-cal__action gp-cal__action--primary" data-action="pay" data-guide-id="${g.id}" disabled>Proc&eacute;der au paiement</button>
            </div>
          </div>
          </div>
        </div>
        </div>
      `;
      list.appendChild(card);
    });

    // Les popups calendrier vont dans <body> : le transform du hover
    // sur la carte casserait leur position: fixed sinon.
    list.querySelectorAll('.gp-cal').forEach(c => document.body.appendChild(c));

    wireUpEvents();
  }

  function renderCalendar(guideId: string) {
    const state = calStates[guideId];
    if (!state) return;
    const monthLabel = document.getElementById(`cal-month-${guideId}`);
    const grid = document.getElementById(`cal-grid-${guideId}`);
    if (!monthLabel || !grid) return;

    monthLabel.textContent = `${MONTH_NAMES[state.month]} ${state.year}`;
    grid.innerHTML = '';
    const firstDay = new Date(state.year, state.month, 1).getDay();
    const offset = firstDay === 0 ? 6 : firstDay - 1;
    const daysInMonth = new Date(state.year, state.month + 1, 0).getDate();
    const today = new Date(); today.setHours(0,0,0,0);

    for (let i = 0; i < offset; i++) {
      const e = document.createElement('span');
      e.className = 'gp-cal__day gp-cal__day--empty';
      grid.appendChild(e);
    }
    for (let d = 1; d <= daysInMonth; d++) {
      const dateStr = `${state.year}-${String(state.month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
      const isPast = new Date(state.year, state.month, d) < today;
      const free = isPast ? [] : freeSlotsFor(guideId, dateStr);
      const isAvail = free.length > 0;
      const isSelected = state.selectedDate === dateStr;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = String(d);
      btn.className = 'gp-cal__day';
      if (isAvail) btn.classList.add('gp-cal__day--available');
      else btn.classList.add('gp-cal__day--unavailable');
      if (isPast) btn.classList.add('gp-cal__day--past');
      if (isSelected) btn.classList.add('gp-cal__day--selected');
      if (isAvail) {
        btn.addEventListener('click', () => {
          state.selectedDate = dateStr;
          state.selectedSlot = null;
          renderCalendar(guideId);
          const sel = document.getElementById(`cal-sel-${guideId}`);
          const dateEl = document.getElementById(`cal-date-${guideId}`);
          if (sel && dateEl) {
            const [y,m2,d2] = dateStr.split('-').map(Number);
            dateEl.textContent = `Date sélectionnée : ${new Date(y,m2-1,d2).toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long',year:'numeric'})}`;
            sel.classList.remove('is-hidden');
            // Replie le calendrier pour laisser la place aux créneaux
            const wrap = document.getElementById(`cal-wrap-${guideId}`);
            const reopen = document.getElementById(`cal-reopen-${guideId}`);
            if (wrap && reopen) {
              wrap.classList.add('is-collapsed');
              reopen.classList.remove('is-hidden');
              reopen.classList.remove('is-open');
            }
            // Seuls les créneaux encore libres de cette date sont cliquables
            const freeNow = freeSlotsFor(guideId, dateStr);
            sel.querySelectorAll('.gp-cal__slot').forEach(b => {
              const slotName = (b as HTMLElement).dataset.slot!;
              const isFree = freeNow.includes(slotName);
              (b as HTMLButtonElement).disabled = !isFree;
              b.classList.toggle('is-unavailable', !isFree);
              b.classList.remove('is-selected');
            });
            sel.querySelectorAll('.gp-cal__action').forEach(a => (a as HTMLButtonElement).disabled = true);
          }
        });
      } else { btn.disabled = true; }
      grid.appendChild(btn);
    }
  }

  function openReviewsModal(guideId: string) {
    const g = getGuides().find((x: any) => x.id === guideId);
    if (!g) return;
    const reviews = getApprovedReviews(guideId);
    const itemsHtml = reviews.map((r: any) => `
      <article class="gp-rvmodal__item">
        <div class="gp-rvmodal__item-head">
          <span class="gp-rvmodal__stars">${starsRowHtml(r.stars || 5)}</span>
          <span class="gp-rvmodal__author">${esc(r.name || 'Anonyme')}</span>
        </div>
        ${(r.text || '').trim() ? `<p class="gp-rvmodal__text">&ldquo;${esc(r.text)}&rdquo;</p>` : ''}
      </article>`).join('');

    const overlay = document.createElement('div');
    overlay.className = 'gp-rvmodal';
    overlay.innerHTML = `
      <div class="gp-rvmodal__panel">
        <button type="button" class="gp-rvmodal__close" aria-label="Fermer">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <h3 class="gp-rvmodal__title">Tous les avis</h3>
        <p class="gp-rvmodal__guide">sur ${esc(g.firstName)} ${esc(g.lastName)} &middot; ${reviews.length} avis</p>
        <div class="gp-rvmodal__list">${itemsHtml}</div>
      </div>`;
    document.body.appendChild(overlay);
    document.body.style.overflow = 'hidden';

    function close() {
      overlay.remove();
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onKey);
    }
    function onKey(e: KeyboardEvent) { if (e.key === 'Escape') close(); }
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
    overlay.querySelector('.gp-rvmodal__close')?.addEventListener('click', close);
    document.addEventListener('keydown', onKey);
  }

  function wireUpEvents() {
    document.querySelectorAll('[data-all-reviews]').forEach(btn => {
      btn.addEventListener('click', () => {
        openReviewsModal((btn as HTMLElement).dataset.allReviews!);
      });
    });
    document.querySelectorAll('[data-toggle-profile]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.toggleProfile!;
        const profile = document.getElementById(`profile-${id}`);
        if (!profile) return;
        const isOpen = profile.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', String(isOpen));
        btn.classList.toggle('is-open', isOpen);
        if (!isOpen) {
          const cal = document.getElementById(`cal-${id}`);
          if (cal) cal.classList.add('is-hidden');
        }
      });
    });
    document.querySelectorAll('[data-open-cal]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.openCal!;
        const cal = document.getElementById(`cal-${id}`);
        if (!cal) return;
        document.querySelectorAll('.gp-cal').forEach(c => c.classList.add('is-hidden'));
        if (!calStates[id]) {
          const now = new Date();
          calStates[id] = { year: now.getFullYear(), month: now.getMonth(), selectedDate: null, selectedSlot: null };
        }
        renderCalendar(id);
        // Réinitialise : calendrier visible, bouton de réouverture masqué
        const wrap = document.getElementById(`cal-wrap-${id}`);
        const reopen = document.getElementById(`cal-reopen-${id}`);
        wrap?.classList.remove('is-collapsed');
        reopen?.classList.add('is-hidden');
        cal.classList.remove('is-hidden');
        document.body.style.overflow = 'hidden';
      });
    });
    document.querySelectorAll('[data-cal-reopen]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.calReopen!;
        const wrap = document.getElementById(`cal-wrap-${id}`);
        if (!wrap) return;
        const nowCollapsed = wrap.classList.toggle('is-collapsed');
        btn.classList.toggle('is-open', !nowCollapsed);
      });
    });
    function closeCal(cal: Element) {
      cal.classList.add('is-hidden');
      document.body.style.overflow = '';
    }
    document.querySelectorAll('[data-cal-close]').forEach(btn => {
      btn.addEventListener('click', () => {
        const cal = btn.closest('.gp-cal');
        if (cal) closeCal(cal);
      });
    });
    document.querySelectorAll('.gp-cal').forEach(cal => {
      cal.addEventListener('click', (e) => {
        if (e.target === cal) closeCal(cal);
      });
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.gp-cal:not(.is-hidden)').forEach(c => closeCal(c));
      }
    });
    document.querySelectorAll('.gp-cal__slot').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.guideId!;
        const s = calStates[id];
        if (!s?.selectedDate) return;
        s.selectedSlot = (btn as HTMLElement).dataset.slot!;
        const sel = document.getElementById(`cal-sel-${id}`);
        if (sel) {
          sel.querySelectorAll('.gp-cal__slot').forEach(b => b.classList.remove('is-selected'));
          btn.classList.add('is-selected');
          sel.querySelectorAll('.gp-cal__action').forEach(a => (a as HTMLButtonElement).disabled = false);
        }
      });
    });
    document.querySelectorAll('[data-cal-prev]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.calPrev!;
        const s = calStates[id]; if (!s) return;
        s.month--; if (s.month < 0) { s.month = 11; s.year--; }
        renderCalendar(id);
      });
    });
    document.querySelectorAll('[data-cal-next]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.calNext!;
        const s = calStates[id]; if (!s) return;
        s.month++; if (s.month > 11) { s.month = 0; s.year++; }
        renderCalendar(id);
      });
    });
    document.querySelectorAll('[data-action="browse"]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.guideId!;
        const s = calStates[id]; if (!s?.selectedDate || !s.selectedSlot) return;
        const ok = await createBooking(id, s.selectedDate, s.selectedSlot);
        if (!ok) return;
        s.selectedDate = null;
        s.selectedSlot = null;
        renderCalendar(id);
        const sel = document.getElementById(`cal-sel-${id}`);
        if (sel) sel.classList.add('is-hidden');
        const calEl = document.getElementById(`cal-${id}`);
        if (calEl) closeCal(calEl);
        const card = document.querySelector(`article[data-guide-id="${id}"]`) as HTMLElement;
        if (card) {
          card.style.borderColor = '#14513A';
          card.style.boxShadow = '0 0 0 2px rgba(20,81,58,0.15)';
          if (!card.querySelector('.gp-card__booked')) {
            const badge = document.createElement('span');
            badge.className = 'gp-card__booked';
            badge.textContent = 'Réservé';
            card.querySelector('.gp-card__right')?.prepend(badge);
          }
        }
      });
    });
    document.querySelectorAll('[data-action="pay"]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.guideId!;
        const s = calStates[id]; if (!s?.selectedDate || !s.selectedSlot) return;
        const ok = await createBooking(id, s.selectedDate, s.selectedSlot);
        if (!ok) return;
        await redirectToCheckout();
      });
    });
  }

  async function createBooking(guideId: string, date: string, slot: string): Promise<boolean> {
    const guide = getGuides().find((g: any) => g.id === guideId);
    const { data, error } = await supabase.rpc('create_booking', {
      p_guide_id: guideId,
      p_date: date,
      p_slot: slot,
      p_activity_slug: null,
      p_activity_name: null,
    });
    if (error || !data) {
      alert("Cette date n'est plus disponible. Le calendrier a été mis à jour.");
      await loadData();
      renderCalendar(guideId);
      return false;
    }

    const bm = (BOOKED[guideId] = BOOKED[guideId] || {});
    (bm[date] = bm[date] || []).push(slot);

    // Panier local du visiteur : référence de SA réservation (id + jeton d'annulation)
    const cart = JSON.parse(localStorage.getItem('omra-cart') || '[]');
    cart.push({
      bookingId: data.id,
      cancelToken: data.cancel_token,
      guideId,
      guideName: guide ? `${guide.firstName} ${guide.lastName}` : 'Guide',
      guidePhoto: guide?.photo || '',
      date,
      slot,
      activityName: '',
      price: guide?.pricePerDay || 0,
    });
    localStorage.setItem('omra-cart', JSON.stringify(cart));
    window.dispatchEvent(new Event('cart-updated'));
    return true;
  }

  async function redirectToCheckout() {
    const cart = JSON.parse(localStorage.getItem('omra-cart') || '[]');
    if (cart.length === 0) return;

    const bookingIds = cart.map((item: any) => item.bookingId);

    try {
      const res = await fetch(
        `${import.meta.env.PUBLIC_SUPABASE_URL || 'https://sraygiyydntxazaaypno.supabase.co'}/functions/v1/create-checkout`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            bookingIds,
            successUrl: `${window.location.origin}/paiement/confirmation/?session_id={CHECKOUT_SESSION_ID}`,
            cancelUrl: `${window.location.origin}/guides/`,
          }),
        },
      );
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        alert(data.error || 'Erreur lors de la création du paiement.');
      }
    } catch {
      alert('Erreur de connexion. Veuillez réessayer.');
    }
  }

  loadData().then(renderGuidesList);
</script>

